<div class='settings-container'>
    <h1 class='page-title'>API Pricing</h1>
    <p class='text-sm text-gray-600 dark:text-gray-400 mb-6 max-w-2xl'>
        Programmatic access to your collection, prices, and the IWMM card catalog.
        See <a class='text-link' href='/api/docs'>the API docs</a> to get started.
    </p>

    {{#if notice}}
    <div class='mb-4 rounded-lg border border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20 p-3 text-sm'>
        {{notice}}
    </div>
    {{/if}}

    <div class='grid grid-cols-1 md:grid-cols-3 gap-6'>
        {{#each tiers}}
        <div
            class='section-container flex flex-col {{#if this.isCurrent}}border-teal-500 border-2{{/if}}'>
            <div class='flex items-baseline justify-between'>
                <h3 class='page-subtitle'>{{this.label}}</h3>
                {{#if this.isCurrent}}
                <span
                    class='text-xs px-2 py-1 rounded-full bg-teal-500 text-white uppercase tracking-wide'>Current</span>
                {{/if}}
            </div>
            <div class='mt-3 mb-2'>
                <span class='text-3xl font-semibold'>{{this.pricePerMonth}}</span>
                {{#unless this.isFree}}
                <span class='text-sm text-gray-500'>/month</span>
                {{/unless}}
            </div>
            <p class='text-sm text-gray-600 dark:text-gray-400 mb-4'>{{this.description}}</p>
            <ul class='flex-1 space-y-2 text-sm'>
                {{#each this.features}}
                <li class='flex items-start gap-2'>
                    <i class='fas fa-check text-teal-500 mt-1'></i>
                    <span>{{this}}</span>
                </li>
                {{/each}}
            </ul>
            <div class='mt-6'>
                {{#if this.isFree}}
                {{#if @root.authenticated}}
                <a class='btn btn-secondary w-full text-center' href='/user/api-keys'>Manage API Keys</a>
                {{else}}
                <a class='btn btn-secondary w-full text-center' href='/user/create'>Create account</a>
                {{/if}}
                {{else if this.isCurrent}}
                <form method='POST' action='/developer/billing/portal'>
                    <button type='submit' class='btn btn-secondary w-full'>Manage Billing</button>
                </form>
                {{else}}
                {{#if @root.authenticated}}
                <form method='POST' action='/developer/billing/checkout'>
                    <input type='hidden' name='tier' value='{{this.tier}}' />
                    <button type='submit' class='btn btn-primary w-full'>Upgrade to {{this.label}}</button>
                </form>
                {{else}}
                <a class='btn btn-primary w-full text-center'
                    href='/auth/login?next=/developer/pricing'>Log in to upgrade</a>
                {{/if}}
                {{/if}}
            </div>
        </div>
        {{/each}}
    </div>

    <div class='mt-10 text-center'>
        <p class='text-sm text-gray-500 dark:text-gray-400'>
            All limits apply per user account. Need higher volume?
            <a class='text-link' href='mailto:legal@iwantmymtg.net'>Contact us.</a>
        </p>
    </div>
</div>
