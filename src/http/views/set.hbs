<link href="/public/css/mana.css?v={{assetVersion}}" rel="stylesheet" type="text/css" />
<div id="set-header-container" class="relative">
    <section class="bg-teal-50 dark:bg-midnight-900 mb-4 pb-5 rounded-b-lg">
        <div class="text-center pt-4 pb-2">
            <h1 class="page-title">
                <i class="ss ss-{{set.keyruneCode}} ss-2x ss-foil mr-2 align-middle"></i>
                <span class="align-middle">{{set.name}}</span>
                {{>tags item=set}}
            </h1>
        </div>

        <div class="max-w-2xl mx-auto px-4">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
                {{>statCard label="Block" value=set.block valueClass="text-sm"}}
                {{>statCard label="Code" value=(toUpperCase set.code)}}
                {{>statCard label="Released" value=set.releaseDate valueClass="text-sm"}}
                {{>statCard label="Set Price" value=set.prices.defaultPrice}}
            </div>

            {{#if authenticated}}
            <div class="grid grid-cols-3 gap-3 mb-4">
                <div class="stat-card stat-card-highlight">
                    <span class="stat-label">Owned</span>
                    <span class="stat-value">{{set.ownedTotal}}<span class="text-xs font-normal text-gray-400 dark:text-gray-500">/{{set.effectiveSize}}</span></span>
                </div>
                {{>statCard label="Owned Value" value=set.ownedValue highlight=true}}
                <div class="stat-card stat-card-highlight">
                    <span class="stat-label">Completion</span>
                    <div class="mt-1">{{>completionRate set}}</div>
                </div>
            </div>
            <div class="mb-4">
                <a href="/inventory/sets/{{set.code}}" class="btn btn-ghost text-sm">
                    <i class="fas fa-book-open mr-1"></i> My Binder
                </a>
            </div>
            {{/if}}

            {{#if (gt set.prices.gridCols 1)}}
            <div class="flex justify-center mb-4">
                <button type="button" id="price-info-toggle"
                    class="btn btn-secondary text-sm px-3 py-1.5"
                    aria-label="View detailed set prices">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                        </path>
                    </svg>
                    Price Info
                </button>
            </div>
            {{/if}}

            <div class="action-card">
                <span class="action-card-label">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    Collection
                </span>
                {{#if authenticated}}
                <form method="POST" action="/sets/{{set.code}}/inventory">
                    <div class="flex justify-center gap-4 mb-3">
                        <span class="flex items-center gap-1.5">
                            <label class="flex items-center gap-1.5 text-sm text-gray-600 dark:text-gray-300 cursor-pointer">
                                <input type="checkbox" name="foil" value="true" class="rounded" />
                                Include foils
                            </label>
                            <span class="relative inline-block">
                                <button type="button"
                                    class="collection-tooltip-trigger text-gray-400 dark:text-gray-500 hover:text-teal-600 dark:hover:text-teal-400 transition-colors"
                                    aria-label="Foil info">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                                <span class="collection-tooltip hidden absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-midnight-800 dark:bg-midnight-700 text-white text-xs rounded-lg p-2 shadow-lg z-10 w-48 text-center">
                                    Also add foil versions of each card
                                    <span class="absolute top-full left-1/2 -translate-x-1/2 -mt-1 w-2 h-2 bg-midnight-800 dark:bg-midnight-700 transform rotate-45"></span>
                                </span>
                            </span>
                        </span>
                        <span class="flex items-center gap-1.5">
                            <label class="flex items-center gap-1.5 text-sm text-gray-600 dark:text-gray-300 cursor-pointer">
                                <input type="checkbox" name="include_variants" value="true" class="rounded" />
                                Include variants
                            </label>
                            <span class="relative inline-block">
                                <button type="button"
                                    class="collection-tooltip-trigger text-gray-400 dark:text-gray-500 hover:text-teal-600 dark:hover:text-teal-400 transition-colors"
                                    aria-label="Variants info">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                                <span class="collection-tooltip hidden absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-midnight-800 dark:bg-midnight-700 text-white text-xs rounded-lg p-2 shadow-lg z-10 w-48 text-center">
                                    Also add extended art, showcase, borderless, and other variant cards
                                    <span class="absolute top-full left-1/2 -translate-x-1/2 -mt-1 w-2 h-2 bg-midnight-800 dark:bg-midnight-700 transform rotate-45"></span>
                                </span>
                            </span>
                        </span>
                    </div>
                    <div class="flex flex-wrap gap-2 justify-center items-center">
                        <button type="submit" class="btn btn-primary text-sm px-3 py-1.5">Add All Cards</button>
                        <a href="/sets/{{set.code}}/checklist" class="btn btn-secondary text-sm px-3 py-1.5">My Checklist</a>
                    </div>
                </form>
                {{else}}
                <div class="flex flex-wrap gap-2 justify-center">
                    <a href="/sets/{{set.code}}/checklist" class="btn btn-secondary text-sm px-3 py-1.5">Blank Checklist</a>
                </div>
                {{/if}}
            </div>
        </div>

        {{! Popover - positioned relative to #set-header-container }}
        <div id="price-info-popover" class="absolute hidden left-4 right-4 top-full mt-2 z-50" role="dialog"
            aria-modal="false" aria-labelledby="popover-title">
            <div id="popover-content"
                class="bg-white dark:bg-midnight-800 rounded-lg shadow-2xl border-2 border-teal-500 dark:border-teal-400 overflow-hidden max-h-[70vh] overflow-y-auto mx-auto max-w-6xl">
                {{! Header }}
                <div class="bg-teal-500 dark:bg-teal-600 text-white px-4 py-3 flex items-center justify-between sticky top-0 z-10">
                    <h3 id="popover-title" class="text-lg md:text-xl font-bold flex items-center space-x-2">
                        <i class="ss ss-{{set.keyruneCode}} ss-2x"></i>
                        <span>{{set.name}} Prices</span>
                    </h3>
                    <button type="button" id="close-popover" class="text-white hover:text-teal-100 transition-colors"
                        aria-label="Close price details">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M6 18L18 6M6 6l12 12">
                            </path>
                        </svg>
                    </button>
                </div>

                {{! Content }}
                <div class="p-4 md:p-6">
                    <div
                        class="mb-4 text-xs md:text-sm text-gray-700 dark:text-gray-300 bg-teal-50 dark:bg-teal-900/20 border-l-4 border-teal-400 p-3 rounded">
                        {{#if (eq set.baseSize set.totalSize)}}
                        <p><strong>{{set.baseSize}}</strong> total cards</p>
                        {{else}}
                        {{#if set.baseSize }}
                        <p><strong>Base Set:</strong> the first {{set.baseSize}} cards in set</p>
                        {{/if}}
                        <p class="mt-1">
                            <strong>All Cards:</strong> Base set + bonus/extended cards
                            ({{set.totalSize}} total)
                        </p>
                        {{/if}}
                    </div>
                    {{! Price Grid }}
                    <div class="grid grid-cols-1
                        {{#if (gt set.prices.gridCols 1)}}
                        sm:grid-cols-2
                        {{else}}
                        sm:grid-cols-1
                        {{/if}}
                        {{#if (gt set.prices.gridCols 3)}}
                        lg:grid-cols-4
                        {{/if}}
                        {{#if (eq set.prices.gridCols 3)}}
                        lg:grid-cols-3
                        {{/if}}
                        {{#if (eq set.prices.gridCols 2)}}
                        lg:grid-cols-2
                        {{/if}}
                        {{#if (lt set.prices.gridCols 2)}}
                        lg:grid-cols-1
                        {{/if}}
                        gap-3 md:gap-4">
                        {{! Base Set - Normal }}
                        {{#if set.prices.basePriceNormal}}
                        <div data-price-type="base-normal"
                            class="price-tile price-tile-active border-teal-300 dark:border-teal-600 bg-white dark:bg-midnight-800 ring-teal-400 dark:ring-teal-500"
                            onclick="window.setActivePriceType && window.setActivePriceType('base-normal')">
                            <h4 class="font-semibold text-teal-700 dark:text-teal-300 text-xs uppercase tracking-wide mb-1">
                                Base Set
                            </h4>
                            <div class="price-tile-value font-bold text-gray-900 dark:text-gray-100 font-mono">
                                {{set.prices.basePriceNormal}}
                            </div>
                            {{#if set.prices.basePriceNormalChangeWeekly}}
                            <span class="price-change price-change-{{set.prices.basePriceNormalChangeWeeklySign}} text-xs">{{set.prices.basePriceNormalChangeWeekly}}</span>
                            {{/if}}
                            {{#if set.baseSize}}
                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">{{set.baseSize}} cards</div>
                            {{/if}}
                        </div>
                        {{/if}}

                        {{! Base Set - With Foils }}
                        {{#if set.prices.basePriceAll}}
                        <div data-price-type="base-foil"
                            class="price-tile price-tile-inactive border-purple-300 dark:border-purple-600 bg-purple-50 dark:bg-purple-950/30 ring-purple-400 dark:ring-purple-500"
                            onclick="window.setActivePriceType && window.setActivePriceType('base-foil')">
                            <h4 class="font-semibold text-purple-700 dark:text-purple-300 text-xs uppercase tracking-wide mb-1">
                                Base Set
                                <span
                                    class="text-xs bg-purple-200 dark:bg-purple-800 text-purple-800 dark:text-purple-200 px-1 py-0.5 rounded inline-block">
                                    + Foils
                                </span>
                            </h4>
                            <div class="price-tile-value font-bold text-purple-900 dark:text-purple-200 font-mono">
                                {{set.prices.basePriceAll}}
                            </div>
                            {{#if set.prices.basePriceAllChangeWeekly}}
                            <span class="price-change price-change-{{set.prices.basePriceAllChangeWeeklySign}} text-xs">{{set.prices.basePriceAllChangeWeekly}}</span>
                            {{/if}}
                            {{#if set.baseSize}}
                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">{{set.baseSize}} cards</div>
                            {{/if}}
                        </div>
                        {{/if}}

                        {{! All Cards - Normal }}
                        {{#if set.prices.totalPriceNormal}}
                        <div data-price-type="total-normal"
                            class="price-tile price-tile-inactive border-teal-300 dark:border-teal-600 bg-teal-50 dark:bg-teal-900/20 ring-teal-400 dark:ring-teal-500"
                            onclick="window.setActivePriceType && window.setActivePriceType('total-normal')">
                            <h4 class="font-semibold text-teal-700 dark:text-teal-300 text-xs uppercase tracking-wide mb-1">
                                All Cards
                            </h4>
                            <div class="price-tile-value font-bold text-teal-900 dark:text-teal-200 font-mono">
                                {{set.prices.totalPriceNormal}}
                            </div>
                            {{#if set.prices.totalPriceNormalChangeWeekly}}
                            <span class="price-change price-change-{{set.prices.totalPriceNormalChangeWeeklySign}} text-xs">{{set.prices.totalPriceNormalChangeWeekly}}</span>
                            {{/if}}
                            {{#if set.totalSize}}
                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">{{set.totalSize}} cards</div>
                            {{/if}}
                        </div>
                        {{/if}}

                        {{! All Cards - With Foils }}
                        {{#if set.prices.totalPriceAll}}
                        <div data-price-type="total-foil"
                            class="price-tile price-tile-inactive border-purple-300 dark:border-purple-600 bg-purple-50 dark:bg-purple-950/30 ring-purple-400 dark:ring-purple-500"
                            onclick="window.setActivePriceType && window.setActivePriceType('total-foil')">
                            <h4 class="font-semibold text-purple-700 dark:text-purple-300 text-xs uppercase tracking-wide mb-1">
                                All Cards
                                <span
                                    class="text-xs bg-purple-200 dark:bg-purple-800 text-purple-800 dark:text-purple-200 px-1 py-0.5 rounded inline-block">
                                    + Foils
                                </span>
                            </h4>
                            <div class="price-tile-value font-bold text-purple-900 dark:text-purple-200 font-mono">
                                {{set.prices.totalPriceAll}}
                            </div>
                            {{#if set.prices.totalPriceAllChangeWeekly}}
                            <span class="price-change price-change-{{set.prices.totalPriceAllChangeWeeklySign}} text-xs">{{set.prices.totalPriceAllChangeWeekly}}</span>
                            {{/if}}
                            {{#if set.totalSize}}
                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">{{set.totalSize}} cards</div>
                            {{/if}}
                        </div>
                        {{/if}}
                    </div>

                    {{! Price History Chart }}
                    <div id="set-price-history-chart" data-set-code="{{set.code}}"
                        data-base-size="{{set.baseSize}}" data-total-size="{{set.totalSize}}"
                        data-chart-src="/public/js/setPriceHistoryChart.js?v={{assetVersion}}"
                        data-chart-init="initSetPriceHistory"
                        class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
                        <div class="flex items-center justify-between mb-3">
                            <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Price History</h4>
                            <div class="flex gap-1">
                                <button class="history-range-btn set-price-history-range active px-2 py-1 text-xs rounded" data-days="7">1w</button>
                                <button class="history-range-btn set-price-history-range px-2 py-1 text-xs rounded" data-days="30">30d</button>
                                <button class="history-range-btn set-price-history-range px-2 py-1 text-xs rounded" data-days="365">1y</button>
                                <button class="history-range-btn set-price-history-range px-2 py-1 text-xs rounded">All</button>
                            </div>
                        </div>
                        <div id="set-price-legend" class="flex flex-wrap gap-x-4 gap-y-1 mb-2 text-xs"></div>
                        <div id="set-price-history-canvas-wrapper" style="position: relative; height: 250px;">
                            <canvas id="set-price-history-canvas"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{! End Set Price Info }}
    </section>
</div>

<div id="set-card-list-ajax" data-set-code="{{set.code}}" data-authenticated="{{authenticated}}" class="content-wrapper">
    <div class="flex items-center gap-2">
        <div class="flex-1" id="filter-wrapper">
            {{>filter}}
        </div>
        {{#if baseOnlyToggle.visible}}
        <a href="{{baseOnlyToggle.url}}" id="base-only-wrapper"
           class="btn {{#if baseOnlyToggle.isBaseOnly}} btn-secondary {{else}} btn-primary {{/if}}
                  whitespace-nowrap h-[42px] !inline-flex items-center justify-center flex-shrink-0 mb-4">
            {{baseOnlyToggle.text}}
        </a>
        {{/if}}
        <div class="flex items-center gap-1 flex-shrink-0 mb-4" id="view-toggle">
            <button type="button" class="view-toggle-btn view-toggle-active" data-view="list" aria-label="List view">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
            <button type="button" class="view-toggle-btn view-toggle-inactive" data-view="binder" aria-label="Binder view">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="5" height="5" rx="0.5" />
                    <rect x="10" y="3" width="5" height="5" rx="0.5" />
                    <rect x="17" y="3" width="5" height="5" rx="0.5" />
                    <rect x="3" y="10" width="5" height="5" rx="0.5" />
                    <rect x="10" y="10" width="5" height="5" rx="0.5" />
                    <rect x="17" y="10" width="5" height="5" rx="0.5" />
                    <rect x="3" y="17" width="5" height="5" rx="0.5" />
                    <rect x="10" y="17" width="5" height="5" rx="0.5" />
                    <rect x="17" y="17" width="5" height="5" rx="0.5" />
                </svg>
            </button>
        </div>
    </div>
    <div id="filter-results">
        {{#if set.cards.length}}
        <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>{{>tableHeadersRow}}</thead>
            <tbody>
                {{#each set.cards}}
                <tr class="table-row">
                    {{#if ../authenticated}}
                    <td class="table-cell">
                        {{>invStepper card=this compact=true}}
                    </td>
                    {{/if}}
                    <td class="table-cell">{{this.number}}</td>
                    <td class="table-cell">
                        {{>cardLink url=this.url name=this.name imgSrc=this.imgSrc item=this}}
                    </td>
                    <td class="table-cell xs-hide">{{>manaCost card=this}}</td>
                    <td class="table-cell xs-hide">{{this.rarity}}</td>
                    {{#if ../hasAnyNormalPrice}}
                    <td class="table-cell xs-hide">
                        {{#if this.hasNormal}}
                        <span class="price-normal">{{this.normalPrice}}</span>
                        {{#if this.priceChangeWeekly}}
                        <span class="price-change price-change-{{this.priceChangeWeeklySign}}">{{this.priceChangeWeekly}}</span>
                        {{/if}}
                        {{/if}}
                    </td>
                    {{/if}}
                    {{#if ../hasAnyFoilPrice}}
                    <td class="table-cell xs-hide">
                        {{#if this.hasFoil}}
                        <span class="price-foil">{{this.foilPrice}}</span>
                        {{#if this.foilPriceChangeWeekly}}
                        <span class="price-change price-change-{{this.foilPriceChangeWeeklySign}}">{{this.foilPriceChangeWeekly}}</span>
                        {{/if}}
                        {{/if}}
                    </td>
                    {{/if}}
                    {{#if ../hasAnyPrice}}
                    <td class="table-cell xs-show">
                        {{#if this.hasNormal}}
                        <span class="price-normal">{{this.normalPrice}}</span>
                        {{#if this.priceChangeWeekly}}
                        <span class="price-change price-change-{{this.priceChangeWeeklySign}}">{{this.priceChangeWeekly}}</span>
                        {{/if}}
                        {{/if}}
                        {{#if this.hasFoil}}
                        <span class="price-foil">{{this.foilPrice}}</span>
                        {{#if this.foilPriceChangeWeekly}}
                        <span class="price-change price-change-{{this.foilPriceChangeWeeklySign}}">{{this.foilPriceChangeWeekly}}</span>
                        {{/if}}
                        {{/if}}
                    </td>
                    {{/if}}
                </tr>
                {{/each}}
            </tbody>
        </table>
        </div>
        {{else}}
        {{>emptyState icon="search" message="No cards match your search" hint="Try a different search term or clear your filter." buttonHref=(concat "/sets/" set.code) buttonText="Clear Filter"}}
        {{/if}}
    </div>
</div>
{{>pagination hasItems=set.cards.length}}

<script src="/public/js/ajaxUtils.js?v={{assetVersion}}" defer></script>
<script src="/public/js/binderRenderer.js?v={{assetVersion}}" defer></script>
<script src="/public/js/binderCore.js?v={{assetVersion}}" defer></script>
<script src="/public/js/setCardListAjax.js?v={{assetVersion}}" defer></script>
<script src="/public/js/updateInventory.js?v={{assetVersion}}" defer></script>
<script src="/public/js/tooltipManager.js?v={{assetVersion}}" defer></script>
<script src="/public/js/setPriceInfo.js?v={{assetVersion}}" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    new TooltipManager({
        triggerSelector: '.collection-tooltip-trigger',
        tooltipSelector: '.collection-tooltip',
    });
});
</script>
<script src="/public/js/chartLoader.js?v={{assetVersion}}" defer></script>
