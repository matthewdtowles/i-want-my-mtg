{{~!--
  Sealed product list partial - renders the sealed tab body on the set page.

  Parameters:
    products        - SealedProductRowDto[] (required)
    authenticated   - boolean; when true, the owned column is rendered
    subscribed      - boolean; subscribers see the stepper, free users see a Premium link
--~}}
<div class="content-wrapper">
    <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>
                <tr>
                    {{#if authenticated}}
                    <th class="table-cell">Owned</th>
                    {{/if}}
                    <th class="table-cell">Product</th>
                    <th class="table-cell xs-hide">Category</th>
                    <th class="table-cell xs-hide">Subtype</th>
                    <th class="table-cell xs-hide">Contents</th>
                </tr>
            </thead>
            <tbody>
                {{#each products}}
                <tr class="table-row">
                    {{#if ../authenticated}}
                    <td class="table-cell">
                        {{#if ../subscribed}}
                        <div class="sealed-inv-stepper" data-sealed-uuid="{{this.uuid}}">
                            <div class="inv-stepper inv-stepper--sm">
                                <button type="button" class="sealed-inv-btn sealed-inv-btn--dec inv-stepper-btn inv-stepper-btn--dec"
                                        aria-label="Decrease quantity"{{#unless this.ownedQuantity}} disabled{{/unless}}>
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M5 12h14"/></svg>
                                </button>
                                <span class="sealed-inv-qty inv-stepper-qty{{#unless this.ownedQuantity}} sealed-inv-qty--zero inv-stepper-qty--zero{{/unless}}" role="status" aria-live="polite">{{#if this.ownedQuantity}}{{this.ownedQuantity}}{{else}}0{{/if}}</span>
                                <button type="button" class="sealed-inv-btn sealed-inv-btn--inc inv-stepper-btn inv-stepper-btn--inc"
                                        aria-label="Increase quantity">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M12 5v14M5 12h14"/></svg>
                                </button>
                            </div>
                        </div>
                        {{else}}
                        <a href="/pricing" class="text-xs text-amber-600 dark:text-amber-400 hover:underline" title="Sealed product tracking is a Premium feature">
                            <i class="fas fa-star text-xs mr-0.5" aria-hidden="true"></i>Premium
                        </a>
                        {{/if}}
                    </td>
                    {{/if}}
                    <td class="table-cell">
                        {{>cardLink url=this.detailUrl name=this.name imgSrc=this.imageUrl}}
                    </td>
                    <td class="table-cell xs-hide">
                        {{#if this.categoryLabel}}{{this.categoryLabel}}{{/if}}
                    </td>
                    <td class="table-cell xs-hide">
                        {{#if this.subtypeLabel}}{{this.subtypeLabel}}{{/if}}
                    </td>
                    <td class="table-cell xs-hide text-xs text-gray-500 dark:text-gray-400">
                        {{#if this.contentsSummary}}{{this.contentsSummary}}{{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>
