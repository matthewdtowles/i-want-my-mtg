<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="text-center py-16">
        <i class="fas fa-wifi text-6xl text-gray-400 dark:text-gray-600 mb-6" aria-hidden="true"></i>
        <h1 class="text-2xl font-semibold text-gray-700 dark:text-gray-300 mt-4">You're Offline</h1>
        <p class="text-gray-500 dark:text-gray-400 mt-2">Check your internet connection and try again.</p>
        <button onclick="location.reload()"
            class="mt-6 inline-block px-6 py-2 rounded-md bg-teal-500 hover:bg-teal-600 text-white font-medium transition-colors">
            Retry
        </button>
    </div>
</section>
