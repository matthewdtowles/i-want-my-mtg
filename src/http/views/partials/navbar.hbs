{{!-- Toast --}}
<div id="response-message" class="response-message bg-{{#if toast}}{{toast.status}}{{else}}info{{/if}} hidden" role="alert">
    <div class="toast-body">
        <div class="toast-icon">
            {{#if (eq toast.status 'success')}}
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            {{else if (eq toast.status 'error')}}
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {{else if (eq toast.status 'warning')}}
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            {{else}}
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {{/if}}
        </div>
        <span class="toast-text">{{toast.message}}</span>
        <button class="toast-close" id="toast-close-btn" aria-label="Close notification">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
    <div class="toast-progress"><div class="toast-progress-bar" id="toast-progress-bar"></div></div>
</div>

<script src="/public/js/toast.js?v={{assetVersion}}" defer></script>
<script src="/public/js/theme-toggle.js?v={{assetVersion}}" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function () {

    /* ── Toast ── */
    var closeBtn = document.getElementById('toast-close-btn');
    if (closeBtn) {
        closeBtn.addEventListener('click', function () {
            if (typeof window.dismissToast === 'function') window.dismissToast();
        });
    }
    var message = document.getElementById('response-message');
    if (message) {
        var toastText = message.querySelector('.toast-text');
        if (toastText && toastText.textContent.trim().length > 0) {
            if (typeof window.showToast === 'function') {
                var status = 'info';
                if (message.classList.contains('bg-success'))      status = 'success';
                else if (message.classList.contains('bg-error'))   status = 'error';
                else if (message.classList.contains('bg-warning')) status = 'warning';
                window.showToast(toastText.textContent.trim(), status);
            }
        }
    }

    /* ── Login return URL ── */
    var currentPath = window.location.pathname + window.location.search;
    if (currentPath && window.location.pathname !== '/auth/login') {
        document.querySelectorAll('.navbar-login-link').forEach(function (link) {
            link.href = '/auth/login?returnUrl=' + encodeURIComponent(currentPath);
        });
    }

    /* ── Drawer ── */
    var overlay   = document.getElementById('nav-overlay');
    var drawer    = document.getElementById('nav-drawer');
    var openBtn   = document.getElementById('nav-menu-btn');
    var closeBtn2 = document.getElementById('nav-drawer-close');

    var FOCUSABLE = 'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])';

    function getDrawerFocusables() {
        return Array.prototype.slice.call(drawer.querySelectorAll(FOCUSABLE))
            .filter(function (el) { return el.offsetParent !== null || el === document.activeElement; });
    }

    function trapTab(e) {
        if (e.key !== 'Tab' || drawer.hidden) return;
        var items = getDrawerFocusables();
        if (items.length === 0) return;
        var first = items[0];
        var last  = items[items.length - 1];
        if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
        }
    }

    // Tracks elements we modified so release can restore prior state
    var inertedEls = [];

    function lockBackground() {
        document.body.style.overflow = 'hidden';
        // Mark direct body children as inert/aria-hidden, but skip any element
        // that contains the drawer or overlay (drawer lives inside <header>).
        inertedEls = [];
        Array.prototype.forEach.call(document.body.children, function (el) {
            if (el.contains(drawer) || el.contains(overlay)) return;
            inertedEls.push({
                el: el,
                hadInert: el.hasAttribute('inert'),
                priorAriaHidden: el.getAttribute('aria-hidden'),
            });
            el.setAttribute('inert', '');
            el.setAttribute('aria-hidden', 'true');
        });
    }

    function releaseBackground() {
        document.body.style.overflow = '';
        inertedEls.forEach(function (rec) {
            if (!rec.hadInert) rec.el.removeAttribute('inert');
            if (rec.priorAriaHidden === null) rec.el.removeAttribute('aria-hidden');
            else rec.el.setAttribute('aria-hidden', rec.priorAriaHidden);
        });
        inertedEls = [];
    }

    function openDrawer() {
        drawer.hidden  = false;
        overlay.classList.add('open');
        // rAF so transition fires after display
        requestAnimationFrame(function () {
            requestAnimationFrame(function () {
                drawer.classList.add('open');
            });
        });
        openBtn.setAttribute('aria-expanded', 'true');
        lockBackground();
        // focus first focusable element
        var first = drawer.querySelector('button, [href], input');
        if (first) first.focus();
    }

    function closeDrawer() {
        drawer.classList.remove('open');
        overlay.classList.remove('open');
        openBtn.setAttribute('aria-expanded', 'false');

        var duration = parseFloat(getComputedStyle(drawer).transitionDuration) || 0;
        if (duration === 0) {
            drawer.hidden = true;
            releaseBackground();
        } else {
            drawer.addEventListener('transitionend', function handler(e) {
                if (e.target !== drawer || e.propertyName !== 'transform') return;
                drawer.hidden = true;
                releaseBackground();
                drawer.removeEventListener('transitionend', handler);
            });
        }
        openBtn.focus();
    }

    if (openBtn)   openBtn.addEventListener('click',   openDrawer);
    if (closeBtn2) closeBtn2.addEventListener('click', closeDrawer);
    if (overlay)   overlay.addEventListener('click',   closeDrawer);

    // Close on Escape, trap Tab inside drawer
    document.addEventListener('keydown', function (e) {
        if (drawer && !drawer.hidden) {
            if (e.key === 'Escape') closeDrawer();
            else if (e.key === 'Tab') trapTab(e);
        }
    });

    /* ── Collection dropdown (WAI-ARIA menu button) ── */
    var ddBtn  = document.getElementById('collection-btn');
    var ddMenu = document.getElementById('collection-menu');

    if (ddBtn && ddMenu) {
        var ddItems = Array.prototype.slice.call(ddMenu.querySelectorAll('[role="menuitem"]'));
        ddItems.forEach(function (item) { item.setAttribute('tabindex', '-1'); });

        function focusItem(idx) {
            if (ddItems.length === 0) return;
            var i = (idx + ddItems.length) % ddItems.length;
            ddItems[i].focus();
        }
        function currentIndex() {
            return ddItems.indexOf(document.activeElement);
        }
        function openDD(focusIdx) {
            ddMenu.hidden = false;
            ddBtn.setAttribute('aria-expanded', 'true');
            ddBtn.querySelector('.iwm-dd-chevron').classList.add('open');
            if (typeof focusIdx === 'number') focusItem(focusIdx);
        }
        function closeDD(returnFocus) {
            ddMenu.hidden = true;
            ddBtn.setAttribute('aria-expanded', 'false');
            ddBtn.querySelector('.iwm-dd-chevron').classList.remove('open');
            if (returnFocus) ddBtn.focus();
        }

        ddBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            ddMenu.hidden ? openDD() : closeDD();
        });

        // Trigger keyboard: Down/Up/Enter/Space open the menu and focus an item
        ddBtn.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                openDD(0);
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                openDD(ddItems.length - 1);
            }
        });

        // Menu keyboard: arrows, Home/End, Esc, Tab
        ddMenu.addEventListener('keydown', function (e) {
            var idx = currentIndex();
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                focusItem(idx + 1);
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                focusItem(idx - 1);
            } else if (e.key === 'Home') {
                e.preventDefault();
                focusItem(0);
            } else if (e.key === 'End') {
                e.preventDefault();
                focusItem(ddItems.length - 1);
            } else if (e.key === 'Escape') {
                e.preventDefault();
                closeDD(true);
            } else if (e.key === 'Tab') {
                // Tab moves focus out of the menu — close without trapping
                closeDD(false);
            }
        });

        // Close on outside click
        document.addEventListener('click', function (e) {
            if (!document.getElementById('collection-dropdown').contains(e.target)) {
                closeDD(false);
            }
        });
    }
});
</script>
