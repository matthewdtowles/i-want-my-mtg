<div class='content-wrapper py-6'>
    <div class='flex items-center justify-between mb-2 flex-wrap gap-3'>
        <div>
            <h1 class='page-title'>Portfolio Analytics</h1>
            <p class='page-subtitle'>Where your collection's value lives - by set, rarity, type, color, or cost basis.</p>
        </div>
        <a href='/portfolio' class='btn btn-ghost text-sm'>&larr; Back to Portfolio</a>
    </div>

    {{#if locked}}
        {{!-- Premium upsell for free users --}}
        <div class='section-container text-center py-12'>
            <div class='max-w-xl mx-auto'>
                <div class='inline-flex items-center justify-center w-14 h-14 rounded-full mb-4
                            bg-gradient-to-br from-teal-400 to-purple-500 text-white shadow-glow-teal'>
                    <svg class='w-7 h-7' fill='none' stroke='currentColor' stroke-width='2' viewBox='0 0 24 24'>
                        <path stroke-linecap='round' stroke-linejoin='round' d='M9 19V6l12-3v13M9 19c0 1.66-1.34 3-3 3s-3-1.34-3-3 1.34-3 3-3 3 1.34 3 3zm12-3c0 1.66-1.34 3-3 3s-3-1.34-3-3 1.34-3 3-3 3 1.34 3 3z'/>
                    </svg>
                </div>
                <h2 class='font-display font-bold text-xl text-gray-900 dark:text-white mb-2'>Advanced analytics is a Premium feature</h2>
                <p class='text-gray-600 dark:text-gray-400 mb-6 leading-relaxed'>
                    Break down your collection&rsquo;s value by set, rarity, or card type. See which slices of your collection are pulling the most weight - and where to look next.
                </p>

                <div class='grid grid-cols-3 gap-3 max-w-md mx-auto mb-8 text-left'>
                    <div class='p-3 rounded-xl bg-gray-50 dark:bg-midnight-900 border border-gray-200 dark:border-midnight-700'>
                        <div class='text-xs uppercase tracking-wider text-purple-600 dark:text-purple-400 font-semibold mb-1'>By Set</div>
                        <div class='text-xs text-gray-500 dark:text-gray-400'>Which sets dominate your collection value</div>
                    </div>
                    <div class='p-3 rounded-xl bg-gray-50 dark:bg-midnight-900 border border-gray-200 dark:border-midnight-700'>
                        <div class='text-xs uppercase tracking-wider text-purple-600 dark:text-purple-400 font-semibold mb-1'>By Rarity</div>
                        <div class='text-xs text-gray-500 dark:text-gray-400'>Mythics vs rares vs the rest</div>
                    </div>
                    <div class='p-3 rounded-xl bg-gray-50 dark:bg-midnight-900 border border-gray-200 dark:border-midnight-700'>
                        <div class='text-xs uppercase tracking-wider text-purple-600 dark:text-purple-400 font-semibold mb-1'>By Type</div>
                        <div class='text-xs text-gray-500 dark:text-gray-400'>Creatures, lands, artifacts, and beyond</div>
                    </div>
                </div>

                <div class='flex flex-wrap gap-3 justify-center'>
                    <a href='/pricing' class='pricing-btn pricing-btn-cta' style='width:auto; padding:0.7rem 1.75rem;'>See Premium plans</a>
                    <a href='/billing' class='pricing-btn pricing-btn-ghost' style='width:auto; padding:0.7rem 1.5rem;'>Upgrade now</a>
                </div>
            </div>
        </div>
    {{else}}
        {{!-- Dimension switcher --}}
        <div class='section-container'>
            <div class='flex items-center justify-between flex-wrap gap-3 mb-4'>
                <div class='inline-flex flex-wrap rounded-lg border border-gray-200 dark:border-midnight-600 bg-gray-50 dark:bg-midnight-800 p-1'>
                    <a href='/portfolio/breakdown?by=set' class='breakdown-tab {{#if (eq dimension "set")}}active{{/if}}' data-dimension='set'>By Set</a>
                    <a href='/portfolio/breakdown?by=rarity' class='breakdown-tab {{#if (eq dimension "rarity")}}active{{/if}}' data-dimension='rarity'>By Rarity</a>
                    <a href='/portfolio/breakdown?by=type' class='breakdown-tab {{#if (eq dimension "type")}}active{{/if}}' data-dimension='type'>By Type</a>
                    <a href='/portfolio/breakdown?by=color' class='breakdown-tab {{#if (eq dimension "color")}}active{{/if}}' data-dimension='color'>By Color</a>
                    <a href='/portfolio/breakdown?by=cost-basis' class='breakdown-tab {{#if (eq dimension "cost-basis")}}active{{/if}}' data-dimension='cost-basis'>By Cost Basis</a>
                </div>
                <div class='text-sm text-gray-600 dark:text-gray-400'>
                    Portfolio total: <span class='font-mono font-semibold text-gray-900 dark:text-gray-100'>{{totalValueFormatted}}</span>
                    <span class='mx-2'>&middot;</span>
                    {{totalItems}} item{{#unless (eq totalItems 1)}}s{{/unless}}
                </div>
            </div>

            {{#if (eq dimension "color")}}
                <div class='mb-4'>
                    <div class='flex flex-wrap items-center gap-2' role='group' aria-label='Filter by color'>
                        <span class='text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 mr-1'>Filter</span>
                        {{#each colorChips}}
                            <a href='{{href}}' class='breakdown-color-chip color-{{code}} {{#if active}}active{{/if}}' aria-label='{{#if active}}Remove {{label}} filter{{else}}Add {{label}} filter{{/if}}'>
                                <span class='breakdown-color-dot' aria-hidden='true'></span>{{label}}
                            </a>
                        {{/each}}
                    </div>
                    {{#if filterLabel}}
                        <p class='text-xs text-gray-600 dark:text-gray-400 mt-2'>
                            Showing cards containing <span class='font-semibold text-gray-800 dark:text-gray-200'>{{filterLabel}}</span>.
                            <a href='/portfolio/breakdown?by=color' class='underline hover:no-underline'>Clear</a>
                        </p>
                    {{/if}}
                    <p class='text-xs text-gray-500 dark:text-gray-400 mt-2'>
                        A card counts toward every color in its identity, so these rows overlap and don&rsquo;t add up to 100%.
                    </p>
                </div>
            {{/if}}

            {{#if slices.length}}
                <div class='breakdown-list' data-dimension='{{dimension}}' data-colors='{{#each selectedColors}}{{this}}{{#unless @last}},{{/unless}}{{/each}}'>
                    {{#each slices}}
                        <div class='breakdown-row' id='slice-{{key}}' data-key='{{key}}' data-loaded='{{#if expanded}}true{{else}}false{{/if}}'>
                            <a href='{{expandHref}}' class='breakdown-row-toggle' role='button'
                               aria-expanded='{{#if expanded}}true{{else}}false{{/if}}'
                               aria-controls='slice-cards-{{key}}'>
                                <div class='breakdown-row-header'>
                                    <span class='breakdown-label'>
                                        <i class='fas fa-chevron-right breakdown-chevron' aria-hidden='true'></i>
                                        {{label}}
                                    </span>
                                    <span class='breakdown-stats'>
                                        <span class='breakdown-percent'>{{percentFormatted}}</span>
                                        <span class='breakdown-value'>{{valueFormatted}}</span>
                                    </span>
                                </div>
                                <div class='breakdown-bar'>
                                    <div class='breakdown-bar-fill' style='width: {{percentFormatted}};'></div>
                                </div>
                                <div class='breakdown-meta'>{{cardCount}} unique &middot; {{itemCount}} item{{#unless (eq itemCount 1)}}s{{/unless}}</div>
                            </a>
                            <div class='breakdown-cards' id='slice-cards-{{key}}'{{#unless expanded}} hidden{{/unless}}>
                                {{#if expanded}}
                                    {{#if cards.length}}
                                        {{#each cards}}
                                            <div class='breakdown-card-row'>
                                                <span class='breakdown-card-name'>{{> cardLink url=cardUrl name=name imgSrc=imgSrc}}</span>
                                                <span class='breakdown-card-detail'>
                                                    <span class='breakdown-card-set'>{{toUpperCase setCode}} #{{number}}</span>
                                                    <span class='breakdown-card-qty'>{{quantity}}&times;</span>
                                                    <span class='breakdown-card-value'>{{valueFormatted}}</span>
                                                </span>
                                            </div>
                                        {{/each}}
                                    {{else}}
                                        <p class='breakdown-cards-empty'>No cards found in this slice.</p>
                                    {{/if}}
                                {{/if}}
                            </div>
                        </div>
                    {{/each}}
                </div>
            {{else}}
                <div class='py-8'>
                    <div class='max-w-2xl mx-auto text-center mb-6'>
                        <div class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-300 mb-3'>
                            <i class='fas fa-chart-bar text-lg' aria-hidden='true'></i>
                        </div>
                        <h2 class='font-display font-bold text-lg text-gray-900 dark:text-white mb-1'>Nothing to break down yet</h2>
                        <p class='text-gray-600 dark:text-gray-400 text-sm leading-relaxed'>
                            Once you have cards in your inventory, your real breakdown will appear here.
                            Below is a preview of what to expect.
                        </p>
                    </div>
                    <div class='breakdown-list opacity-60 pointer-events-none' aria-hidden='true'>
                        <div class='breakdown-row'>
                            <div class='breakdown-row-header'><span class='breakdown-label'>Sample slice A</span><span class='breakdown-stats'><span class='breakdown-percent'>42.0%</span><span class='breakdown-value'>$420.00</span></span></div>
                            <div class='breakdown-bar'><div class='breakdown-bar-fill' style='width: 42%;'></div></div>
                            <div class='breakdown-meta'>12 unique &middot; 18 items</div>
                        </div>
                        <div class='breakdown-row'>
                            <div class='breakdown-row-header'><span class='breakdown-label'>Sample slice B</span><span class='breakdown-stats'><span class='breakdown-percent'>28.5%</span><span class='breakdown-value'>$285.00</span></span></div>
                            <div class='breakdown-bar'><div class='breakdown-bar-fill' style='width: 28.5%;'></div></div>
                            <div class='breakdown-meta'>9 unique &middot; 11 items</div>
                        </div>
                        <div class='breakdown-row'>
                            <div class='breakdown-row-header'><span class='breakdown-label'>Sample slice C</span><span class='breakdown-stats'><span class='breakdown-percent'>18.0%</span><span class='breakdown-value'>$180.00</span></span></div>
                            <div class='breakdown-bar'><div class='breakdown-bar-fill' style='width: 18%;'></div></div>
                            <div class='breakdown-meta'>7 unique &middot; 7 items</div>
                        </div>
                        <div class='breakdown-row'>
                            <div class='breakdown-row-header'><span class='breakdown-label'>Sample slice D</span><span class='breakdown-stats'><span class='breakdown-percent'>11.5%</span><span class='breakdown-value'>$115.00</span></span></div>
                            <div class='breakdown-bar'><div class='breakdown-bar-fill' style='width: 11.5%;'></div></div>
                            <div class='breakdown-meta'>4 unique &middot; 5 items</div>
                        </div>
                    </div>
                    <div class='text-center mt-6'>
                        <a href='/sets' class='btn btn-primary text-sm px-4 py-2'>Browse Sets to add cards</a>
                    </div>
                </div>
            {{/if}}
        </div>
    {{/if}}
</div>
<script>
    (function () {
        var STORAGE_KEY = 'iwmtg.portfolioBreakdownDimension';
        var validDims = ['set', 'rarity', 'type', 'color', 'cost-basis'];
        var params = new URLSearchParams(window.location.search);
        var current = params.get('by');
        if (!current) {
            try {
                var saved = localStorage.getItem(STORAGE_KEY);
                if (saved && validDims.indexOf(saved) !== -1 && saved !== 'set') {
                    window.location.replace('/portfolio/breakdown?by=' + encodeURIComponent(saved));
                    return;
                }
            } catch (e) { /* ignore */ }
        } else if (validDims.indexOf(current) !== -1) {
            try { localStorage.setItem(STORAGE_KEY, current); } catch (e) { /* ignore */ }
        }
        document.querySelectorAll('.breakdown-tab[data-dimension]').forEach(function (tab) {
            tab.addEventListener('click', function () {
                try { localStorage.setItem(STORAGE_KEY, tab.dataset.dimension); } catch (e) { /* ignore */ }
            });
        });
    })();
</script>
<script src="/public/js/portfolioBreakdown.js?v={{assetVersion}}" defer></script>
