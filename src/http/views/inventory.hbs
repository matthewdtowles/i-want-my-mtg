{{#if hasInventory}}
<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    <section class="bg-teal-50 dark:bg-midnight-900 mb-4 rounded-t-lg pb-5">
        <div class="text-center pt-4 pb-2">
            <h3 class="page-title">{{this.username}}'s Inventory</h3>
        </div>

        <div class="max-w-2xl mx-auto px-4">
            <div class="grid grid-cols-3 gap-3 mb-4">
                <div class="stat-card stat-card-highlight">
                    <span class="stat-label">Total Cards</span>
                    <span class="stat-value">{{this.ownedTotal}}</span>
                </div>
                <div class="stat-card stat-card-highlight">
                    <span class="stat-label">Value</span>
                    <span class="stat-value">{{this.ownedValue}}</span>
                </div>
                <div class="stat-card stat-card-highlight">
                    <span class="stat-label">Completion</span>
                    <div class="mt-1">{{>completionRate}}</div>
                </div>
            </div>

            <div class="flex justify-center gap-2 mb-4">
                <a href="/portfolio" class="btn btn-secondary text-sm px-3 py-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
                    </svg>
                    Portfolio
                </a>
                <a href="/transactions" class="btn btn-secondary text-sm px-3 py-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Transactions
                </a>
            </div>

            <div class="action-card">
                <span class="action-card-label">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                    </svg>
                    Import & Export
                </span>
                <div class="flex flex-wrap gap-2 justify-center items-center">
                    <a href="/inventory/export" class="btn btn-primary text-sm px-3 py-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                        Export CSV
                    </a>
                    <label for="import-cards-file" class="btn btn-secondary text-sm px-3 py-1.5 cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Import Cards
                    </label>
                    <label for="import-sets-file" class="btn btn-secondary text-sm px-3 py-1.5 cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Import Sets
                    </label>
                </div>
                <p class="mt-3 pt-2 border-t border-gray-200 dark:border-midnight-600 text-xs text-center">
                    <a href="/inventory/import-export-guide" class="text-teal-600 dark:text-teal-400 hover:underline font-medium">Import & Export Guide</a>
                </p>
            </div>
        </div>

        <form id="import-cards-form" method="POST" action="/inventory/import/cards" enctype="multipart/form-data" class="hidden">
            <input id="import-cards-file" type="file" name="file" accept=".csv" onchange="this.form.submit()" />
        </form>
        <form id="import-sets-form" method="POST" action="/inventory/import/sets" enctype="multipart/form-data" class="hidden">
            <input id="import-sets-file" type="file" name="file" accept=".csv" onchange="this.form.submit()" />
        </form>
    </section>
    <div id="inventory-list-ajax" class="content-wrapper">
        <div class="flex items-center gap-2">
            <div class="flex-1">
                {{>filter}}
            </div>
            {{#if baseOnlyToggle.visible}}
            <a href="{{baseOnlyToggle.url}}"
               class="btn {{#if baseOnlyToggle.isBaseOnly}} btn-secondary {{else}} btn-primary {{/if}}
                      whitespace-nowrap h-[42px] flex items-center justify-center flex-shrink-0 mb-4">
                {{baseOnlyToggle.text}}
            </a>
            {{/if}}
        </div>
        <div id="filter-results">
            {{#if cards.length}}
            <div class="table-wrapper">
            <table class="table-container w-full">
                <thead>{{>tableHeadersRow}}</thead>
                <tbody>
                    {{#each cards as |card|}}
                    <tr class="table-row">
                        <td class="table-cell">{{>cardsOwned card=card}}</td>
                        <td class="table-cell" data-id="{{card.cardId}}" data-img-src="{{card.imgSrc}}">
                            <a href="{{card.url}}" class="card-name-link">{{card.name}}</a>
                            {{>tags item=card}}
                            <a href="{{card.url}}" class="card-img-link">
                                <img src="{{card.imgSrc}}" alt="{{card.name}}" class="card-img-preview" />
                            </a>
                        </td>
                        <td class="table-cell">
                            <a href="/sets/{{card.setCode}}" class="table-link">
                                <i class="ss ss-{{card.setCode}} ss-{{toLowerCase card.rarity}} ss-fw"></i>
                                {{toUpperCase card.setCode}}
                            </a>
                        </td>
                        <td class="table-cell">
                            <span class="price-{{#if card.isFoil}}foil{{else}}normal{{/if}}">
                                {{card.priceValue}}
                            </span>
                        </td>
                        <td class="table-cell delete-inventory-entry xs-hide">
                            <form class="delete-inventory-form" data-item-id="{{card.cardId}}">
                                <input type="hidden" name="card-id" value="{{card.cardId}}" />
                                <input type="hidden" name="isFoil" value="{{card.isFoil}}" />

                                <button type="button" class="delete-inventory-button">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            </div>
            {{else}}
            <div class="text-center py-16">
                <i class="fas fa-search text-4xl text-gray-300 dark:text-gray-600 mb-4"></i>
                <p class="text-lg text-gray-600 dark:text-gray-400 font-medium mt-4">No items match your current filters</p>
                <p class="text-gray-400 dark:text-gray-500 mt-2">Try a different search term or adjust your filters.</p>
                <a href="/inventory" class="btn btn-secondary mt-6 inline-block">Clear Filters</a>
            </div>
            {{/if}}
        </div>
    </div>
    {{>pagination hasItems=this.cards.length}}
</section>

{{else}}
<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    <div class="bg-teal-50 dark:bg-midnight-900 rounded-lg pb-5">
        <div class="text-center pt-8 pb-2">
            <i class="fas fa-box-open text-5xl text-teal-300 dark:text-teal-600 mb-4"></i>
            <h3 class="page-title mt-4">{{this.username}}'s collection is empty</h3>
            <p class="text-gray-400 dark:text-gray-500 mt-2 max-w-md mx-auto">Browse sets to find cards and start tracking your collection.</p>
            <a href="/sets" class="btn btn-primary inline-block mt-6">Browse Sets</a>
        </div>
        <div class="max-w-md mx-auto px-4 mt-6">
            <div class="action-card">
                <span class="action-card-label">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                    </svg>
                    Import & Export
                </span>
                <div class="flex flex-wrap gap-2 justify-center items-center">
                    <label for="import-cards-file-empty" class="btn btn-secondary text-sm px-3 py-1.5 cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Import Cards
                    </label>
                    <label for="import-sets-file-empty" class="btn btn-secondary text-sm px-3 py-1.5 cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Import Sets
                    </label>
                </div>
                <p class="mt-3 pt-2 border-t border-gray-200 dark:border-midnight-600 text-xs text-center">
                    <a href="/inventory/import-export-guide" class="text-teal-600 dark:text-teal-400 hover:underline font-medium">Import & Export Guide</a>
                </p>
            </div>
        </div>
        <form method="POST" action="/inventory/import/cards" enctype="multipart/form-data" class="hidden">
            <input id="import-cards-file-empty" type="file" name="file" accept=".csv" onchange="this.form.submit()" />
        </form>
        <form method="POST" action="/inventory/import/sets" enctype="multipart/form-data" class="hidden">
            <input id="import-sets-file-empty" type="file" name="file" accept=".csv" onchange="this.form.submit()" />
        </form>
    </div>
</section>
{{/if}}

<script src="/public/js/cardPreview.js" defer></script>
<script src="/public/js/updateInventory.js" defer></script>
<script src="/public/js/inventoryListAjax.js" defer></script>
<script src="/public/js/tooltipManager.js" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    new TooltipManager({
        triggerSelector: '.import-export-tooltip-trigger',
        tooltipSelector: '.import-export-tooltip',
    });
});
</script>
