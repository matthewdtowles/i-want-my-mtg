{
    "name": "i-want-my-mtg",
    "version": "1.19.2-rc.1",
    "description": "MTG Collection Tracker",
    "author": "Matthew Towles",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "prebuild": "./scripts/prebuild.sh",
        "build": "nest build",
        "build:css": "npx tailwindcss -i ./src/http/styles/tailwind.css -o ./src/http/public/css/tailwind.css",
        "build:css:min": "mkdir -p dist/http/public/css && npx tailwindcss -i ./src/http/styles/tailwind.css -o ./dist/http/public/css/tailwind.css --minify",
        "build:js": "./scripts/build-js.sh",
        "build:mana": "./scripts/build-mana.sh",
        "build:sw": "./scripts/build-sw.sh",
        "build:prod": "rm -rf dist && npm run build:mana && npm run build && npm run build:css:min && npm run build:js && npm run build:sw",
        "build:assets": "npm run build:mana && npm run build:css && npm run build:js && npm run build:sw",
        "format": "prettier --write \"src/**/*.{js,ts,json,css}\" \"test/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.{js,ts,json,css}\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "npm run build:mana && npm run build:sw && nest start --watch",
        "start:debug": "npm run build:mana && npm run build:sw && nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest --maxWorkers=50%",
        "test:watch": "jest --watch --maxWorkers=25%",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:frontend": "jest --config ./test/jest-frontend.json",
        "test:integ": "./scripts/test-integ.sh",
        "test:pw": "npx playwright test",
        "test:pw:full": "./scripts/test-e2e-playwright.sh",
        "test:pw:ui": "npx playwright test --ui",
        "test:pw:headed": "npx playwright test --headed",
        "test:pw:report": "npx playwright show-report",
        "setup": "./scripts/setup.sh",
        "migrate": "./scripts/migrate.sh",
        "reset-db": "./scripts/reset-db.sh",
        "logs": "./scripts/logs.sh",
        "db-backup": "./scripts/db-backup.sh",
        "free-docker-port": "./scripts/free-docker-port.sh",
        "gen-api-key": "./scripts/gen-api-key.sh",
        "etl": "./scripts/etl.sh",
        "lighthouse": "./scripts/lighthouse.sh",
        "lighthouse:prod": "./scripts/lighthouse.sh --base-url=https://iwantmymtg.net",
        "bump": "npm version patch --no-git-tag-version",
        "bump:minor": "npm version minor --no-git-tag-version",
        "bump:major": "npm version major --no-git-tag-version",
        "bump:dev": "npm version prerelease --preid=rc --no-git-tag-version"
    },
    "dependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/config": "^3.2.2",
        "@nestjs/core": "^10.0.0",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/mapped-types": "^2.0.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.3.8",
        "@nestjs/swagger": "^7.4.2",
        "@nestjs/typeorm": "^10.0.2",
        "axios": "^1.9.0",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.6",
        "csv-parse": "^6.1.0",
        "csv-stringify": "^6.6.0",
        "express-handlebars": "^9.0.1",
        "handlebars": "^4.7.8",
        "mana-font": "^1.18.0",
        "nodemailer": "^7.0.13",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.14.1",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.1",
        "swagger-ui-express": "^5.0.1",
        "typeorm": "^0.3.20",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.4",
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.7",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.14",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.3.1",
        "@types/nodemailer": "^7.0.9",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/supertest": "^6.0.0",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^8.57.1",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "prettier": "^3.8.1",
        "supertest": "^6.3.4",
        "tailwindcss": "^3.4.18",
        "terser": "^5.46.1",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3"
    },
    "overrides": {
        "multer": "^2.1.1",
        "path-to-regexp@^0": "0.1.13",
        "lodash": "^4.18.0",
        "semver": "^7.6.0",
        "glob@>=10.2.0": "^10.5.0",
        "minimatch@>=9.0.0": "^9.0.7"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!src/**/*.d.ts",
            "!src/main.ts",
            "!src/**/index.ts",
            "!src/**/test-utils.ts",
            "!src/**/mock.*.ts",
            "!src/**/*dto*.ts",
            "!src/**/*entity*.ts",
            "!src/**/*module*.ts",
            "!src/**/*port*.ts"
        ],
        "coverageDirectory": "./coverage",
        "coverageReporters": [
            "lcov",
            "text",
            "html"
        ],
        "testEnvironment": "node",
        "moduleNameMapper": {
            "^src/(.*)$": "<rootDir>/src/$1"
        },
        "testPathIgnorePatterns": [
            "/node_modules/"
        ],
        "testMatch": [
            "<rootDir>/test/**/*.spec.ts"
        ],
        "maxWorkers": "50%",
        "testTimeout": 10000,
        "cache": true,
        "cacheDirectory": ".jest-cache"
    }
}
