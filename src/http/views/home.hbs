<section class="home-hero font-display">
    <div class="home-hero-bg" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto px-5 py-16 md:py-24 text-center">
        <div class="home-hero-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            Track your collection, free forever &middot; No card limits
        </div>
        <h1 class="home-hero-title">
            Your Magic collection,<br />
            <span>tracked and valued.</span>
        </h1>
        <p class="home-hero-sub">
            Know what you own, what it's worth, and what you've spent. Built for serious collectors who want clarity over guesswork.
        </p>
        <div class="home-hero-ctas">
            {{#if authenticated}}
                <a href="/inventory" class="pricing-btn pricing-btn-cta">My collection</a>
                <a href="#set-list" class="pricing-btn pricing-btn-ghost">Browse sets</a>
            {{else}}
                <a href="/user/create" class="pricing-btn pricing-btn-cta">Start tracking free</a>
                <a href="#set-list" class="pricing-btn pricing-btn-ghost">Browse sets</a>
            {{/if}}
        </div>
        <ul class="home-hero-feats">
            <li><i class="fas fa-layer-group" aria-hidden="true"></i> Inventory &amp; sets</li>
            <li><i class="fas fa-chart-line" aria-hidden="true"></i> Live portfolio value</li>
            <li><i class="fas fa-receipt" aria-hidden="true"></i> Buys, sells &amp; gains</li>
        </ul>
    </div>
</section>
<div class="mana-color-bar" aria-hidden="true">
    <span class="mana-w"></span>
    <span class="mana-u"></span>
    <span class="mana-b"></span>
    <span class="mana-r"></span>
    <span class="mana-g"></span>
</div>
<div id="set-list">
{{>setList}}
</div>
