{{~!--
  Inline transaction recording form on card detail page.

  Parameters:
    authenticated — boolean, only renders for logged-in users
    card          — { cardId, normalPriceRaw, foilPriceRaw, hasFoil }
--~}}
{{#if authenticated}}
<div id="transaction-form-section" class="mt-4 border-t border-gray-200 dark:border-midnight-600 pt-4">
    <div class="flex items-center justify-between mb-3">
        <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Record Transaction</h4>
        <a href="/transactions" class="text-xs text-teal-600 dark:text-teal-400 hover:underline">View All</a>
    </div>
    <form id="transaction-form" class="space-y-3">
        <input type="hidden" name="cardId" value="{{card.cardId}}" />

        <div class="grid grid-cols-2 gap-2">
            <div>
                <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Type</label>
                <select name="type" class="w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100">
                    <option value="BUY">Buy</option>
                    <option value="SELL">Sell</option>
                </select>
            </div>
            <div>
                <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Quantity</label>
                <input type="number" name="quantity" value="1" min="1"
                    class="w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100" />
            </div>
        </div>

        <div class="grid grid-cols-2 gap-2">
            <div>
                <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Price Per Unit</label>
                <input type="number" name="pricePerUnit" step="0.01" min="0"
                    value="{{card.normalPriceRaw}}"
                    data-normal-price="{{card.normalPriceRaw}}"
                    data-foil-price="{{card.foilPriceRaw}}"
                    class="w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100 font-mono" />
            </div>
            <div>
                <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Foil</label>
                <select name="isFoil" class="w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100">
                    <option value="false">No</option>
                    {{#if card.hasFoil}}
                    <option value="true">Yes</option>
                    {{/if}}
                </select>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-2">
            <div>
                <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Date</label>
                <input type="date" name="date"
                    class="w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100" />
            </div>
            <div>
                <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Source</label>
                <input type="text" name="source" placeholder="e.g. tcgplayer, lgs"
                    class="w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100" />
            </div>
        </div>

        <div id="transaction-form-message" class="hidden text-xs py-1"></div>

        <button type="submit" class="btn btn-primary w-full text-sm py-1.5">
            Record Transaction
        </button>
    </form>
</div>
{{/if}}
