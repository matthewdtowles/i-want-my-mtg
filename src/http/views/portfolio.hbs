{{#if hasSummary}}
<section class="border border-gray-200 dark:border-midnight-700 rounded-2xl sm:m-0 md:m-4 overflow-hidden">
    <section class="app-page-header mb-4">
        <div class="app-page-header-bg" aria-hidden="true"></div>
        <div class="app-page-header-inner">
            <h1 class="app-page-title font-display">{{this.username}}'s Portfolio</h1>
            <p class="app-page-sub">Current value, cost basis, and performance.</p>
        </div>

        <div class="relative max-w-3xl mx-auto px-4 pb-6">
            <div class="app-stat-tile app-stat-tile--featured mb-3" data-metric-hint="The current market value of all cards in your inventory, based on the latest price data.">
                <span class="app-stat-tile-label">Current Value</span>
                <span class="app-stat-tile-value">{{this.summary.totalValue}}</span>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-4">
                <div class="app-stat-tile">
                    <span class="app-stat-tile-label">Total Invested{{#if this.summary.isFifo}}{{>infoTooltip title="FIFO Cost Basis" description="Cost basis calculated using FIFO (first-in, first-out) - the standard method for tracking real gains. Sells are matched against your oldest buys first."}}{{else}}{{>infoTooltip title="Average Cost Basis" description="Cost basis uses a perpetual average (total spent ÷ units bought). Upgrade to Premium for FIFO cost basis, which matches sells against your oldest buys first - the standard method for tracking real gains."}}{{/if}}</span>
                    <span class="app-stat-tile-value">{{this.summary.totalCost}}</span>
                </div>
                <div class="app-stat-tile" data-metric-hint="Total unique cards in your inventory, and total number of individual copies held.">
                    <span class="app-stat-tile-label">Cards / Units</span>
                    <span class="app-stat-tile-value">{{this.summary.totalCards}} / {{this.summary.totalQuantity}}</span>
                </div>
                {{#if subscribed}}
                <div class="app-stat-tile">
                    <span class="app-stat-tile-label">Unrealized P&L{{#if this.summary.isFifo}}{{>infoTooltip title="FIFO Cost Basis" description="Unrealized P&L calculated using FIFO (first-in, first-out) lot matching for accurate per-unit cost tracking."}}{{else}}{{>infoTooltip title="Based on Average Cost" description="Unrealized P&L uses average cost basis. Click Recalculate below for precise FIFO-based P&L, which is the standard method for tracking real gains."}}{{/if}}</span>
                    <span class="app-stat-tile-value gain-{{this.summary.totalGainSign}}">{{this.summary.totalGain}}</span>
                </div>
                <div class="app-stat-tile" data-metric-hint="Return on investment - your total gain as a percentage of what you have invested.">
                    <span class="app-stat-tile-label">ROI</span>
                    <span class="app-stat-tile-value gain-{{this.summary.roiSign}}">{{this.summary.roi}}</span>
                </div>
                <div class="app-stat-tile" data-metric-hint="Profit or loss from cards you have already sold, calculated using FIFO lot matching.">
                    <span class="app-stat-tile-label">Realized Gains</span>
                    <span class="app-stat-tile-value gain-{{this.summary.realizedGainSign}}">{{this.summary.realizedGain}}</span>
                </div>
                {{else}}
                <a href="/pricing" class="app-stat-tile app-stat-tile--locked" title="Premium feature - upgrade to view P&L">
                    <span class="app-stat-tile-label">Unrealized P&L <i class="fas fa-lock text-amber-500 text-xs ml-1" aria-hidden="true"></i></span>
                    <span class="app-stat-tile-locked-value">$•••</span>
                    <span class="app-stat-tile-premium">Premium</span>
                </a>
                <a href="/pricing" class="app-stat-tile app-stat-tile--locked" title="Premium feature - upgrade to view ROI">
                    <span class="app-stat-tile-label">ROI <i class="fas fa-lock text-amber-500 text-xs ml-1" aria-hidden="true"></i></span>
                    <span class="app-stat-tile-locked-value">•••%</span>
                    <span class="app-stat-tile-premium">Premium</span>
                </a>
                <a href="/pricing" class="app-stat-tile app-stat-tile--locked" title="Premium feature - upgrade to view realized gains">
                    <span class="app-stat-tile-label">Realized Gains <i class="fas fa-lock text-amber-500 text-xs ml-1" aria-hidden="true"></i></span>
                    <span class="app-stat-tile-locked-value">$•••</span>
                    <span class="app-stat-tile-premium">Premium</span>
                </a>
                {{/if}}
            </div>

            <div class="flex justify-center gap-2 mb-4">
                <a href="/inventory" class="btn btn-secondary text-sm px-3 py-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                    Inventory
                </a>
                <a href="/transactions" class="btn btn-secondary text-sm px-3 py-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Transactions
                </a>
                <a href="/portfolio/breakdown" class="btn btn-cta text-sm px-3 py-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25A1.125 1.125 0 019.75 19.875V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
                    </svg>
                    Analytics
                    <i class="fas fa-star text-[10px] ml-0.5 text-amber-300" aria-hidden="true" title="Premium feature"></i>
                </a>
            </div>

            <div class="flex flex-col items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                <div class="flex items-center gap-2">
                    <span>Updated: {{this.summary.computedAt}}</span>
                    <span class="px-1.5 py-0.5 rounded {{#if this.summary.isFifo}}bg-teal-100 text-teal-700 dark:bg-teal-900/40 dark:text-teal-300{{else}}bg-gray-100 text-gray-500 dark:bg-gray-800 dark:text-gray-400{{/if}}">{{#if this.summary.isFifo}}FIFO{{else}}Average{{/if}}</span>
                    {{#if this.summary.isFifo}}{{>infoTooltip title="FIFO Cost Basis" description="All metrics use FIFO (first-in, first-out) lot matching - the standard method for tracking real investment gains. Each sale is matched against your oldest purchases first."}}{{else}}{{>infoTooltip title="Average Cost Basis" description="Metrics use a perpetual average cost basis (total spent divided by units bought). Upgrade to Premium for FIFO-based figures, which match sales against your oldest purchases first."}}{{/if}}
                </div>
                {{#if this.summary.canRefresh}}
                <button id="refresh-portfolio-btn" class="btn btn-secondary text-xs px-3 py-1.5">
                    <i class="fas fa-calculator mr-1"></i>Recalculate{{#if this.summary.isFifo}} P&L (FIFO){{/if}} · {{this.summary.refreshesRemaining}} left
                </button>
                {{else}}
                <span class="text-gray-300 dark:text-gray-600">
                    <i class="fas fa-calculator mr-1"></i>No recalculations remaining today
                </span>
                {{/if}}
            </div>
        </div>
    </section>

    {{#if hasHistory}}
    <div class="content-wrapper px-4 pb-6">
        {{#if subscribed}}
        <div id="portfolio-chart-container">
            <div class="flex items-center justify-between mb-3">
                <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Value History</h4>
                <div class="flex gap-1">
                    <button class="portfolio-range active px-2 py-1 text-xs rounded" data-days="7">1w</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded" data-days="30">30d</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded" data-days="365">1y</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded">All</button>
                </div>
            </div>
            <div id="portfolio-legend" class="flex flex-wrap gap-x-4 gap-y-1 mb-2 text-xs"></div>
            <div style="position: relative; height: 350px;">
                <canvas id="portfolio-canvas"></canvas>
            </div>
        </div>
        {{else}}
        {{>upgradeTile heading="Value History Chart" description="Track how your collection's value changes over time. Premium unlocks the full history chart with weekly, monthly, and yearly views." cta="Upgrade to Premium"}}
        {{/if}}
    </div>
    {{/if}}

    {{#if topPerformers.length}}
    <div class="content-wrapper px-4 pb-6">
        <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">
            <i class="fas fa-arrow-trend-up text-teal-500 mr-1"></i>Top Performers
            {{#if this.summary.isFifo}}{{>infoTooltip title="FIFO Cost Basis" description="Cost basis calculated using FIFO (first-in, first-out) lot matching."}}{{else}}{{>infoTooltip title="Average Cost Basis" description="Cost basis shown here uses the average method. Recalculate for FIFO cost basis."}}{{/if}}
        </h4>
        <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>
                <tr class="table-header-row">
                    <th class="table-header">Card</th>
                    <th class="table-header">Qty</th>
                    <th class="table-header">Cost Basis</th>
                    <th class="table-header">Value</th>
                    <th class="table-header">Gain</th>
                    <th class="table-header">ROI</th>
                </tr>
            </thead>
            <tbody>
                {{#each topPerformers as |p|}}
                <tr class="table-row">
                    <td class="table-cell">
                        {{#if p.cardUrl}}
                        {{>cardLink url=p.cardUrl name=p.cardName imgSrc=p.imgSrc}}
                        {{else}}
                        {{p.cardName}}
                        {{/if}}
                        {{#if p.isFoil}}<span class="foil-badge">Foil</span>{{/if}}
                        <span class="text-gray-500 dark:text-gray-400 text-xs">({{p.cardSetCode}})</span>
                    </td>
                    <td class="table-cell">{{p.quantity}}</td>
                    <td class="table-cell font-mono">{{p.totalCost}}</td>
                    <td class="table-cell font-mono">{{p.currentValue}}</td>
                    <td class="table-cell font-mono gain-{{p.totalGainSign}}">{{p.totalGain}}</td>
                    <td class="table-cell font-mono gain-{{p.roiSign}}">{{p.roi}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        </div>
    </div>
    {{/if}}

    {{#if setRoi.length}}
    <div class="content-wrapper px-4 pb-6">
        <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">
            <i class="fas fa-layer-group text-teal-500 mr-1"></i>ROI by Set
            {{#if this.summary.isFifo}}{{>infoTooltip title="FIFO Cost Basis" description="Set-level investment totals use FIFO cost basis aggregated from per-card lot matching."}}{{else}}{{>infoTooltip title="Average Cost Basis" description="Set-level investment totals use average cost basis. Recalculate for FIFO cost basis."}}{{/if}}
        </h4>
        <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>
                <tr class="table-header-row">
                    <th class="table-header">Set</th>
                    <th class="table-header">Cards</th>
                    <th class="table-header">Invested</th>
                    <th class="table-header">Value</th>
                    <th class="table-header">Gain</th>
                    <th class="table-header">ROI</th>
                </tr>
            </thead>
            <tbody>
                {{#each setRoi as |s|}}
                <tr class="table-row">
                    <td class="table-cell">
                        {{>cardLink url=s.setUrl name=s.setName}}
                        <span class="text-gray-500 dark:text-gray-400 text-xs">({{s.setCode}})</span>
                    </td>
                    <td class="table-cell">{{s.cardsHeld}}</td>
                    <td class="table-cell font-mono">{{s.totalCost}}</td>
                    <td class="table-cell font-mono">{{s.currentValue}}</td>
                    <td class="table-cell font-mono gain-{{s.gainSign}}">{{s.gain}}</td>
                    <td class="table-cell font-mono gain-{{s.roiSign}}">{{s.roi}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        </div>
    </div>
    {{/if}}

    {{#if subscribed}}
    <div class="content-wrapper px-4 pb-6">
        <div id="cashflow-chart-container">
            <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">
                <i class="fas fa-money-bill-wave text-teal-500 mr-1"></i>Monthly Cash Flow
            </h4>
            <div style="position: relative; height: 300px;">
                <canvas id="cashflow-canvas"></canvas>
            </div>
        </div>
    </div>
    {{/if}}

    {{#if worstPerformers.length}}
    <div class="content-wrapper px-4 pb-6">
        <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">
            <i class="fas fa-arrow-trend-down text-hotpink-500 mr-1"></i>Worst Performers
            {{#if this.summary.isFifo}}{{>infoTooltip title="FIFO Cost Basis" description="Cost basis calculated using FIFO (first-in, first-out) lot matching."}}{{else}}{{>infoTooltip title="Average Cost Basis" description="Cost basis shown here uses the average method. Recalculate for FIFO cost basis."}}{{/if}}
        </h4>
        <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>
                <tr class="table-header-row">
                    <th class="table-header">Card</th>
                    <th class="table-header">Qty</th>
                    <th class="table-header">Cost Basis</th>
                    <th class="table-header">Value</th>
                    <th class="table-header">Gain</th>
                    <th class="table-header">ROI</th>
                </tr>
            </thead>
            <tbody>
                {{#each worstPerformers as |p|}}
                <tr class="table-row">
                    <td class="table-cell">
                        {{#if p.cardUrl}}
                        {{>cardLink url=p.cardUrl name=p.cardName imgSrc=p.imgSrc}}
                        {{else}}
                        {{p.cardName}}
                        {{/if}}
                        {{#if p.isFoil}}<span class="foil-badge">Foil</span>{{/if}}
                        <span class="text-gray-500 dark:text-gray-400 text-xs">({{p.cardSetCode}})</span>
                    </td>
                    <td class="table-cell">{{p.quantity}}</td>
                    <td class="table-cell font-mono">{{p.totalCost}}</td>
                    <td class="table-cell font-mono">{{p.currentValue}}</td>
                    <td class="table-cell font-mono gain-{{p.totalGainSign}}">{{p.totalGain}}</td>
                    <td class="table-cell font-mono gain-{{p.roiSign}}">{{p.roi}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        </div>
    </div>
    {{/if}}
</section>

<script src="/public/js/tooltipManager.js?v={{assetVersion}}" defer></script>
{{#if subscribed}}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3/dist/chartjs-adapter-date-fns.bundle.min.js" defer></script>
<script src="/public/js/portfolioChart.js?v={{assetVersion}}" defer></script>
<script src="/public/js/cashFlowChart.js?v={{assetVersion}}" defer></script>
{{/if}}
<script>
document.addEventListener('DOMContentLoaded', function () {
    var refreshBtn = document.getElementById('refresh-portfolio-btn');
    if (refreshBtn) {
        var originalLabel = refreshBtn.innerHTML;
        refreshBtn.addEventListener('click', async function () {
            refreshBtn.disabled = true;
            refreshBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Recalculating...';
            try {
                var response = await fetch('/portfolio/refresh', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                });
                var data = await response.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.error || 'Failed to recalculate');
                    refreshBtn.disabled = false;
                    refreshBtn.innerHTML = originalLabel;
                }
            } catch (error) {
                alert('Error recalculating portfolio');
                refreshBtn.disabled = false;
                refreshBtn.innerHTML = originalLabel;
            }
        });
    }
});
</script>

{{else if hasHistory}}
<section class="border border-gray-200 dark:border-midnight-700 rounded-2xl sm:m-0 md:m-4 overflow-hidden">
    <section class="app-page-header mb-4">
        <div class="app-page-header-bg" aria-hidden="true"></div>
        <div class="app-page-header-inner">
            <h1 class="app-page-title font-display">{{this.username}}'s Portfolio</h1>
            <p class="app-page-sub">Portfolio value over time.</p>
        </div>
    </section>
    <div class="content-wrapper px-4 pb-6">
        {{#if subscribed}}
        <div id="portfolio-chart-container">
            <div class="flex items-center justify-between mb-3">
                <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Value History</h4>
                <div class="flex gap-1">
                    <button class="portfolio-range active px-2 py-1 text-xs rounded" data-days="7">1w</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded" data-days="30">30d</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded" data-days="365">1y</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded">All</button>
                </div>
            </div>
            <div id="portfolio-legend" class="flex flex-wrap gap-x-4 gap-y-1 mb-2 text-xs"></div>
            <div style="position: relative; height: 350px;">
                <canvas id="portfolio-canvas"></canvas>
            </div>
        </div>
        {{else}}
        {{>upgradeTile heading="Value History Chart" description="Track how your collection's value changes over time. Premium unlocks the full history chart with weekly, monthly, and yearly views." cta="Upgrade to Premium"}}
        {{/if}}
    </div>
</section>

{{#if subscribed}}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3/dist/chartjs-adapter-date-fns.bundle.min.js" defer></script>
<script src="/public/js/portfolioChart.js?v={{assetVersion}}" defer></script>
{{/if}}
{{else}}
<section class="border border-gray-200 dark:border-midnight-700 rounded-2xl sm:m-0 md:m-4 overflow-hidden">
    {{>emptyState icon="chart-line" iconSize="text-5xl" iconColor="text-teal-300 dark:text-teal-600" padX=true heading="No portfolio history yet" hint="Portfolio value snapshots are taken daily. Add cards to your inventory and check back after the next data refresh." hintWide=true buttonHref="/inventory" buttonText="Go to Inventory" buttonClass="btn-primary"}}
</section>
{{/if}}
