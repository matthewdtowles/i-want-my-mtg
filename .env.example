APP_NAME=i-want-my-mtg
DB_HOST=redacted
DB_PORT=redacted
DB_USERNAME=redacted
DB_PASSWORD=redacted
DB_NAME=redacted
NODE_ENV=dev
SCRY_LOG=debug
TIMING_ENABLED=false
JWT_SECRET=redacted
GITHUB_TOKEN=redacted
DEBUG_MODE=1
LOG_FORMAT=json

# DOCKER - PostgreSQL expects these exact names
POSTGRES_DB=redacted
POSTGRES_USER=redacted
POSTGRES_PASSWORD=redacted
DATABASE_URL=postgresql://user:pwd@postgres:0000/postgres_db

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=000
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@iwantmymtg.net
APP_URL=https://iwantmymtg.net

# Price Alert Processing (generate with: ./scripts/gen-api-key.sh)
INTERNAL_API_KEY=redacted

# Portfolio Summary
PORTFOLIO_REFRESH_MAX_DAILY=3
PORTFOLIO_REFRESH_COOLDOWN_MINUTES=60

# Stripe billing. Leave blank in dev — billing actions return error notices /
# redirect with ?error=checkout_failed until configured (no 500s for the user-facing
# routes), and the webhook endpoint returns 500 if it receives an event while
# misconfigured so Stripe will retry once secrets are set.
# Create one product with a monthly and annual recurring price in the Stripe dashboard
# and paste the price IDs below. Webhook secret is printed by `stripe listen` locally,
# or taken from the endpoint config in the Stripe dashboard in prod.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Display amounts shown on the /billing page. Keep these in sync with the actual
# amounts on the Stripe price IDs above; if unset, the page falls back to $3.99 / $39.99.
STRIPE_DISPLAY_PRICE_MONTHLY=
STRIPE_DISPLAY_PRICE_ANNUAL=
# Optional overrides. Defaults: ${APP_URL}/billing/success?session_id={CHECKOUT_SESSION_ID}
# and ${APP_URL}/billing/canceled. The success URL must include the
# {CHECKOUT_SESSION_ID} placeholder if you customize it.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
