{{~!
  Inline price alert form on card detail page.
  Shows existing alert state when one exists, otherwise shows create form.

  Parameters:
    authenticated - boolean, only renders for logged-in users
    card          - { cardId }
    priceAlert    - { id, increasePct, decreasePct, isActive } (optional)
~}}
{{#if authenticated}}
    <div
        id='price-alert-form-section'
        class='mt-4 border-t border-gray-200 dark:border-midnight-600 pt-4'
    >
        <div class='flex items-center justify-between mb-3'>
            <h4 class='text-sm font-semibold text-gray-700 dark:text-gray-300'>
                Price Alert
                {{#if priceAlert}}
                    {{#if priceAlert.isActive}}
                        <span class='inline-block ml-1.5 px-1.5 py-0.5 text-[0.6rem] font-medium rounded-full bg-teal-100 text-teal-700 dark:bg-teal-900 dark:text-teal-300'>Active</span>
                    {{else}}
                        <span class='inline-block ml-1.5 px-1.5 py-0.5 text-[0.6rem] font-medium rounded-full bg-gray-100 text-gray-500 dark:bg-midnight-700 dark:text-gray-400'>Paused</span>
                    {{/if}}
                {{/if}}
            </h4>
            <a
                href='/price-alerts'
                class='text-xs text-teal-600 dark:text-teal-400 hover:underline'
            >View All</a>
        </div>
        <form id='price-alert-form' class='space-y-3'
            data-alert-id='{{#if priceAlert}}{{priceAlert.id}}{{/if}}'
            data-mode='{{#if priceAlert}}edit{{else}}create{{/if}}'
        >
            <input type='hidden' name='cardId' value='{{card.cardId}}' />

            <div class='grid grid-cols-2 gap-2'>
                <div>
                    <label class='text-xs text-gray-500 dark:text-gray-400 block mb-1'>Increase %</label>
                    <input
                        type='number'
                        name='increasePct'
                        placeholder='e.g. 10'
                        min='0.01'
                        step='0.01'
                        {{#if priceAlert.increasePct}}value='{{priceAlert.increasePct}}'{{/if}}
                        class='w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100'
                    />
                </div>
                <div>
                    <label class='text-xs text-gray-500 dark:text-gray-400 block mb-1'>Decrease %</label>
                    <input
                        type='number'
                        name='decreasePct'
                        placeholder='e.g. 10'
                        min='0.01'
                        step='0.01'
                        {{#if priceAlert.decreasePct}}value='{{priceAlert.decreasePct}}'{{/if}}
                        class='w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100'
                    />
                </div>
            </div>

            <div id='price-alert-form-message' class='hidden text-xs py-1'></div>

            {{#if priceAlert}}
                <div class='flex gap-2'>
                    <button type='submit' class='btn btn-primary flex-1 text-sm py-1.5'>
                        Update Alert
                    </button>
                    <button type='button' id='price-alert-toggle-btn'
                        class='btn btn-secondary text-sm py-1.5 px-3'
                        title='{{#if priceAlert.isActive}}Pause{{else}}Resume{{/if}} alert'
                        aria-label='{{#if priceAlert.isActive}}Pause{{else}}Resume{{/if}} alert'
                    >
                        {{#if priceAlert.isActive}}
                            <i class='fa-solid fa-pause'></i>
                        {{else}}
                            <i class='fa-solid fa-play'></i>
                        {{/if}}
                    </button>
                    <button type='button' id='price-alert-delete-btn'
                        class='btn text-sm py-1.5 px-3 text-red-500 hover:text-red-600 border border-red-300 dark:border-red-700 hover:bg-red-50 dark:hover:bg-red-950 rounded'
                        title='Delete alert'
                        aria-label='Delete alert'
                    >
                        <i class='fa-solid fa-trash'></i>
                    </button>
                </div>
            {{else}}
                <button type='submit' class='btn btn-primary w-full text-sm py-1.5'>
                    Set Price Alert
                </button>
            {{/if}}
        </form>
    </div>
{{/if}}
