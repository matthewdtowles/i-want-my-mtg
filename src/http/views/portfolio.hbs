{{#if hasSummary}}
<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    <section class="bg-teal-50 dark:bg-midnight-900 mb-4 rounded-t-lg pb-5">
        <div class="text-center pt-4 pb-2">
            <h1 class="page-title">{{this.username}}'s Portfolio</h1>
        </div>

        <div class="max-w-3xl mx-auto px-4">
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-4">
                {{>statCard label="Current Value" value=this.summary.totalValue highlight=true}}
                <div class="stat-card stat-card-highlight">
                    <span class="stat-label">Total Invested{{#if this.summary.isFifo}}{{>costBasisTooltip title="FIFO Cost Basis" description="Cost basis calculated using FIFO (first-in, first-out) - the standard method for tracking real gains. Sells are matched against your oldest buys first."}}{{else}}{{>costBasisTooltip title="Average Cost Basis" description="By default, the portfolio snapshot uses average cost basis (total spent ÷ units held). Click Recalculate below for precise FIFO cost basis, which matches sells against your oldest buys first - the standard method for tracking real gains."}}{{/if}}</span>
                    <span class="stat-value">{{this.summary.totalCost}}</span>
                </div>
                <div class="stat-card stat-card-highlight">
                    <span class="stat-label">Unrealized P&L{{#if this.summary.isFifo}}{{>costBasisTooltip title="FIFO Cost Basis" description="Unrealized P&L calculated using FIFO (first-in, first-out) lot matching for accurate per-unit cost tracking."}}{{else}}{{>costBasisTooltip title="Based on Average Cost" description="Unrealized P&L uses average cost basis. Click Recalculate below for precise FIFO-based P&L, which is the standard method for tracking real gains."}}{{/if}}</span>
                    <span class="stat-value gain-{{this.summary.totalGainSign}}">{{this.summary.totalGain}}</span>
                </div>
                {{>statCard label="ROI" value=this.summary.roi highlight=true valueClass=(concat "gain-" this.summary.roiSign)}}
                {{>statCard label="Realized Gains" value=this.summary.realizedGain highlight=true valueClass=(concat "gain-" this.summary.realizedGainSign)}}
                {{>statCard label="Cards / Units" value=(concat this.summary.totalCards " / " this.summary.totalQuantity) highlight=true}}
            </div>

            <div class="flex justify-center gap-2 mb-4">
                <a href="/inventory" class="btn btn-secondary text-sm px-3 py-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                    Inventory
                </a>
                <a href="/transactions" class="btn btn-secondary text-sm px-3 py-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Transactions
                </a>
            </div>

            <div class="flex flex-col items-center gap-2 text-xs text-gray-400 dark:text-gray-500">
                <div class="flex items-center gap-2">
                    <span>Updated: {{this.summary.computedAt}}</span>
                    <span class="px-1.5 py-0.5 rounded {{#if this.summary.isFifo}}bg-teal-100 text-teal-700 dark:bg-teal-900/40 dark:text-teal-300{{else}}bg-gray-100 text-gray-500 dark:bg-gray-800 dark:text-gray-400{{/if}}">{{#if this.summary.isFifo}}FIFO{{else}}Average{{/if}}</span>
                </div>
                {{#if this.summary.canRefresh}}
                <button id="refresh-portfolio-btn" class="btn btn-secondary text-xs px-3 py-1.5">
                    <i class="fas fa-calculator mr-1"></i>Recalculate (FIFO) · {{this.summary.refreshesRemaining}} left
                </button>
                {{else}}
                <span class="text-gray-300 dark:text-gray-600">
                    <i class="fas fa-calculator mr-1"></i>No recalculations remaining today
                </span>
                {{/if}}
            </div>
        </div>
    </section>

    {{#if hasHistory}}
    <div class="content-wrapper px-4 pb-6">
        <div id="portfolio-chart-container">
            <div class="flex items-center justify-between mb-3">
                <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Value History</h4>
                <div class="flex gap-1">
                    <button class="portfolio-range active px-2 py-1 text-xs rounded" data-days="7">1w</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded" data-days="30">30d</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded" data-days="365">1y</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded">All</button>
                </div>
            </div>
            <div id="portfolio-legend" class="flex flex-wrap gap-x-4 gap-y-1 mb-2 text-xs"></div>
            <div style="position: relative; height: 350px;">
                <canvas id="portfolio-canvas"></canvas>
            </div>
        </div>
    </div>
    {{/if}}

    {{#if topPerformers.length}}
    <div class="content-wrapper px-4 pb-6">
        <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">
            <i class="fas fa-arrow-trend-up text-teal-500 mr-1"></i>Top Performers
            {{#if this.summary.isFifo}}{{>costBasisTooltip title="FIFO Cost Basis" description="Cost basis calculated using FIFO (first-in, first-out) lot matching."}}{{else}}{{>costBasisTooltip title="Average Cost Basis" description="Cost basis shown here uses the average method. Recalculate for FIFO cost basis."}}{{/if}}
        </h4>
        <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>
                <tr class="table-header-row">
                    <th class="table-header">Card</th>
                    <th class="table-header">Qty</th>
                    <th class="table-header">Cost Basis</th>
                    <th class="table-header">Value</th>
                    <th class="table-header">Gain</th>
                    <th class="table-header">ROI</th>
                </tr>
            </thead>
            <tbody>
                {{#each topPerformers as |p|}}
                <tr class="table-row">
                    <td class="table-cell">
                        {{#if p.cardUrl}}
                        {{>cardLink url=p.cardUrl name=p.cardName imgSrc=p.imgSrc}}
                        {{else}}
                        {{p.cardName}}
                        {{/if}}
                        {{#if p.isFoil}}<span class="foil-badge">Foil</span>{{/if}}
                        <span class="text-gray-400 dark:text-gray-500 text-xs">({{p.cardSetCode}})</span>
                    </td>
                    <td class="table-cell">{{p.quantity}}</td>
                    <td class="table-cell font-mono">{{p.totalCost}}</td>
                    <td class="table-cell font-mono">{{p.currentValue}}</td>
                    <td class="table-cell font-mono gain-{{p.totalGainSign}}">{{p.totalGain}}</td>
                    <td class="table-cell font-mono gain-{{p.roiSign}}">{{p.roi}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        </div>
    </div>
    {{/if}}

    {{#if setRoi.length}}
    <div class="content-wrapper px-4 pb-6">
        <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">
            <i class="fas fa-layer-group text-teal-500 mr-1"></i>ROI by Set
            {{#if this.summary.isFifo}}{{>costBasisTooltip title="FIFO Cost Basis" description="Set-level investment totals use FIFO cost basis aggregated from per-card lot matching."}}{{else}}{{>costBasisTooltip title="Average Cost Basis" description="Set-level investment totals use average cost basis. Recalculate for FIFO cost basis."}}{{/if}}
        </h4>
        <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>
                <tr class="table-header-row">
                    <th class="table-header">Set</th>
                    <th class="table-header">Cards</th>
                    <th class="table-header">Invested</th>
                    <th class="table-header">Value</th>
                    <th class="table-header">Gain</th>
                    <th class="table-header">ROI</th>
                </tr>
            </thead>
            <tbody>
                {{#each setRoi as |s|}}
                <tr class="table-row">
                    <td class="table-cell">
                        {{>cardLink url=s.setUrl name=s.setName}}
                        <span class="text-gray-400 dark:text-gray-500 text-xs">({{s.setCode}})</span>
                    </td>
                    <td class="table-cell">{{s.cardsHeld}}</td>
                    <td class="table-cell font-mono">{{s.totalCost}}</td>
                    <td class="table-cell font-mono">{{s.currentValue}}</td>
                    <td class="table-cell font-mono gain-{{s.gainSign}}">{{s.gain}}</td>
                    <td class="table-cell font-mono gain-{{s.roiSign}}">{{s.roi}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        </div>
    </div>
    {{/if}}

    <div class="content-wrapper px-4 pb-6">
        <div id="cashflow-chart-container">
            <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">
                <i class="fas fa-money-bill-wave text-teal-500 mr-1"></i>Monthly Cash Flow
            </h4>
            <div style="position: relative; height: 300px;">
                <canvas id="cashflow-canvas"></canvas>
            </div>
        </div>
    </div>

    {{#if worstPerformers.length}}
    <div class="content-wrapper px-4 pb-6">
        <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">
            <i class="fas fa-arrow-trend-down text-hotpink-500 mr-1"></i>Worst Performers
            {{#if this.summary.isFifo}}{{>costBasisTooltip title="FIFO Cost Basis" description="Cost basis calculated using FIFO (first-in, first-out) lot matching."}}{{else}}{{>costBasisTooltip title="Average Cost Basis" description="Cost basis shown here uses the average method. Recalculate for FIFO cost basis."}}{{/if}}
        </h4>
        <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>
                <tr class="table-header-row">
                    <th class="table-header">Card</th>
                    <th class="table-header">Qty</th>
                    <th class="table-header">Cost Basis</th>
                    <th class="table-header">Value</th>
                    <th class="table-header">Gain</th>
                    <th class="table-header">ROI</th>
                </tr>
            </thead>
            <tbody>
                {{#each worstPerformers as |p|}}
                <tr class="table-row">
                    <td class="table-cell">
                        {{#if p.cardUrl}}
                        {{>cardLink url=p.cardUrl name=p.cardName imgSrc=p.imgSrc}}
                        {{else}}
                        {{p.cardName}}
                        {{/if}}
                        {{#if p.isFoil}}<span class="foil-badge">Foil</span>{{/if}}
                        <span class="text-gray-400 dark:text-gray-500 text-xs">({{p.cardSetCode}})</span>
                    </td>
                    <td class="table-cell">{{p.quantity}}</td>
                    <td class="table-cell font-mono">{{p.totalCost}}</td>
                    <td class="table-cell font-mono">{{p.currentValue}}</td>
                    <td class="table-cell font-mono gain-{{p.totalGainSign}}">{{p.totalGain}}</td>
                    <td class="table-cell font-mono gain-{{p.roiSign}}">{{p.roi}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        </div>
    </div>
    {{/if}}
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3/dist/chartjs-adapter-date-fns.bundle.min.js" defer></script>
<script src="/public/js/tooltipManager.js?v={{assetVersion}}" defer></script>
<script src="/public/js/portfolioChart.js?v={{assetVersion}}" defer></script>
<script src="/public/js/cashFlowChart.js?v={{assetVersion}}" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    new TooltipManager({
        triggerSelector: '.cost-basis-tooltip-trigger',
        tooltipSelector: '.cost-basis-tooltip',
    });

    var refreshBtn = document.getElementById('refresh-portfolio-btn');
    if (refreshBtn) {
        refreshBtn.addEventListener('click', async function () {
            refreshBtn.disabled = true;
            refreshBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Recalculating...';
            try {
                var response = await fetch('/portfolio/refresh', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                });
                var data = await response.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.error || 'Failed to recalculate');
                    refreshBtn.disabled = false;
                    refreshBtn.innerHTML = '<i class="fas fa-calculator mr-1"></i>Recalculate (FIFO)';
                }
            } catch (error) {
                alert('Error recalculating portfolio');
                refreshBtn.disabled = false;
                refreshBtn.innerHTML = '<i class="fas fa-calculator mr-1"></i>Recalculate (FIFO)';
            }
        });
    }
});
</script>

{{else if hasHistory}}
<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    <section class="text-center bg-teal-50 dark:bg-midnight-900 mb-4 rounded-t-lg py-4">
        <h1 class="page-title">{{this.username}}'s Portfolio</h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Portfolio value over time</p>
    </section>
    <div class="content-wrapper px-4 pb-6">
        <div id="portfolio-chart-container">
            <div class="flex items-center justify-between mb-3">
                <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Value History</h4>
                <div class="flex gap-1">
                    <button class="portfolio-range active px-2 py-1 text-xs rounded" data-days="7">1w</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded" data-days="30">30d</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded" data-days="365">1y</button>
                    <button class="portfolio-range px-2 py-1 text-xs rounded">All</button>
                </div>
            </div>
            <div id="portfolio-legend" class="flex flex-wrap gap-x-4 gap-y-1 mb-2 text-xs"></div>
            <div style="position: relative; height: 350px;">
                <canvas id="portfolio-canvas"></canvas>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3/dist/chartjs-adapter-date-fns.bundle.min.js" defer></script>
<script src="/public/js/portfolioChart.js?v={{assetVersion}}" defer></script>
{{else}}
<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    {{>emptyState icon="chart-line" iconSize="text-5xl" iconColor="text-teal-300 dark:text-teal-600" padX=true heading="No portfolio history yet" hint="Portfolio value snapshots are taken daily. Add cards to your inventory and check back after the next data refresh." hintWide=true buttonHref="/inventory" buttonText="Go to Inventory" buttonClass="btn-primary"}}
</section>
{{/if}}
