{{#if hasNotifications}}
<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    <section class="text-center bg-teal-50 dark:bg-midnight-900 mb-4 rounded-t-lg py-4">
        <h1 class="page-title">Notifications</h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm mt-1 max-w-md mx-auto">
            Price change notifications for your tracked cards.
        </p>
        <div class="flex justify-center gap-2 mt-2">
            <button id="mark-all-read-btn" class="btn btn-secondary text-sm px-3 py-1.5">
                Mark All Read
            </button>
            <a href="/price-alerts" class="btn btn-secondary text-sm px-3 py-1.5">
                Manage Alerts
            </a>
        </div>
    </section>
    <div id="notification-list-ajax" class="content-wrapper">
        <div id="filter-results">
            <div class="text-center py-16">
                <i class="fas fa-spinner fa-spin text-4xl text-teal-500"></i>
            </div>
        </div>
    </div>
</section>

{{else}}
<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    <div class="bg-teal-50 dark:bg-midnight-900 rounded-lg pb-5">
        <div class="text-center pt-8 pb-2 px-4">
            <i class="fas fa-inbox text-5xl text-teal-300 dark:text-teal-600 mb-4"></i>
            <h3 class="page-title mt-4">No notifications yet</h3>
            <p class="text-gray-500 dark:text-gray-400 mt-2 max-w-md mx-auto">
                Notifications will appear here when your price alerts are triggered.
            </p>
            <div class="flex justify-center gap-2 mt-6">
                <a href="/price-alerts" class="btn btn-primary">Manage Alerts</a>
                <a href="/sets" class="btn btn-secondary">Browse Sets</a>
            </div>
        </div>
    </div>
</section>
{{/if}}

<script src="/public/js/ajaxUtils.js?v={{assetVersion}}" defer></script>
<script src="/public/js/notificationListAjax.js?v={{assetVersion}}" defer></script>
