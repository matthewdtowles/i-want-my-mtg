<div class="text-center py-16 px-4 max-w-xl mx-auto">
    <div class="font-display text-8xl font-bold text-hotpink-500 dark:text-hotpink-400 mb-4">500</div>
    <div class="text-2xl font-semibold text-gray-800 dark:text-gray-200 mb-3">Something Went Wrong</div>
    <div class="text-base text-gray-500 dark:text-gray-400 mb-8">
        {{#if toast}}
            {{toast.message}}
        {{else}}
            An unexpected error occurred on our end. This has been noted - please try again in a moment.
        {{/if}}
    </div>
    <div class="flex gap-4 justify-center flex-wrap">
        <button onclick="window.history.back()" class="btn btn-primary">Go Back</button>
        <a href="/" class="btn btn-secondary">Go Home</a>
    </div>
</div>
