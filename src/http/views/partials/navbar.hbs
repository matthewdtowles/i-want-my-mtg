{{~!--
  Site navigation bar with logo, nav links, auth controls, and toast notifications.

  Parameters:
    authenticated - boolean, toggles login vs. user menu
    welcome       - display name for logged-in user
    toast         - optional { status, message } for flash notifications
    assetVersion  - cache-busting version for toast.js script
--~}}
<nav class="bg-gradient-to-r from-purple-800 via-purple-700 to-purple-800 dark:from-midnight-950 dark:via-purple-950 dark:to-midnight-950 shadow-lg py-4 border-b-2 border-teal-400 dark:shadow-glow-teal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
            <div class="flex items-center">
                <a href="/">
                    <img class="logo" src="/public/images/logo.webp?v={{assetVersion}}" alt="I Want My MTG logo" width="80" height="80" fetchpriority="low" />
                </a>
            </div>
            {{!-- Desktop --}}
            <div class="hidden md:flex space-x-4 items-center">
                <a class="navbar-link" href="/">Home</a>
                <a class="navbar-link" href="/sets">Sets</a>
                <a class="navbar-link" href="/spoilers">Spoilers</a>
                {{#if authenticated}}
                <a class="navbar-link" href="/inventory">My Inventory</a>
                <a class="navbar-link" href="/transactions">Transactions</a>
                <a class="navbar-link" href="/price-alerts">Alerts</a>
                <a class="navbar-link" href="/user">My Account</a>
                <a class="navbar-link bg-amber-500 hover:bg-amber-400 text-midnight-950 font-semibold px-3 py-1 rounded shadow-sm"
                    href="/billing">
                    <i class="fas fa-star text-xs mr-1" aria-hidden="true"></i>Upgrade
                </a>
                <form method="post" action="/auth/logout" class="inline">
                    <button type="submit" class="navbar-link bg-transparent border-0 cursor-pointer p-0">Logout</button>
                </form>
                {{else}}
                <a class="navbar-link navbar-login-link" href="/auth/login">Sign In</a>
                <a class="navbar-link" href="/user/create">Create Account</a>
                {{/if}}
                <form method="get" action="/search" class="flex items-center">
                    <input type="text" name="q" placeholder="Search..." autocomplete="off"
                        class="w-32 lg:w-40 px-2 py-1 text-sm rounded-md
                               bg-purple-900/50 dark:bg-midnight-800/50 border border-purple-600 dark:border-midnight-600
                               text-white placeholder-purple-300 dark:placeholder-gray-400
                               focus:ring-2 focus:ring-teal-400 focus:outline-none focus:border-teal-400" />
                </form>
                <a class="navbar-link" href="/guides/getting-started" title="Getting Started Guide">
                    <i class="fas fa-circle-question text-sm" aria-hidden="true"></i>
                    <span class="sr-only">Getting Started Guide</span>
                </a>
                <button id="theme-toggle" type="button"
                    class="text-teal-300 hover:text-white p-2 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-teal-400"
                    aria-label="Toggle theme">
                    <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
                    </svg>
                    <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
                    </svg>
                </button>
            </div>
            {{!-- Mobile Menu Button--}}
            <div class="md:hidden flex items-center gap-2">
                <button id="theme-toggle-mobile" type="button"
                    class="text-teal-300 hover:text-white p-2 rounded-md transition-colors focus:outline-none"
                    aria-label="Toggle theme">
                    <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
                    </svg>
                    <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
                    </svg>
                </button>
                <button id="mobile-menu-button" aria-label="Open navigation menu"
                    aria-expanded="false" aria-controls="mobile-menu"
                    class="text-teal-300 hover:text-white focus:outline-none focus:ring-2 focus:ring-inset focus:ring-teal-400 p-2 rounded-md">
                    <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16m-7 6h7" />
                    </svg>
                </button>
            </div>
        </div>
    </div>
    {{!-- Mobile Menu --}}
    <div id="mobile-menu" class="hidden md:hidden bg-purple-800 dark:bg-midnight-900 border-t border-purple-600 dark:border-midnight-700">
        <form method="get" action="/search" class="px-4 py-3">
            <input type="text" name="q" placeholder="Search cards and sets..." autocomplete="off"
                class="w-full px-3 py-2 text-sm rounded-md
                       bg-purple-900/50 dark:bg-midnight-800/50 border border-purple-600 dark:border-midnight-600
                       text-white placeholder-purple-300 dark:placeholder-gray-400
                       focus:ring-2 focus:ring-teal-400 focus:outline-none focus:border-teal-400" />
        </form>
        <a class="navbar-link-mobile" href="/">Home</a>
        <a class="navbar-link-mobile" href="/sets">Sets</a>
        <a class="navbar-link-mobile" href="/spoilers">Spoilers</a>
        {{#if authenticated}}
        <a class="navbar-link-mobile" href="/inventory">My Inventory</a>
        <a class="navbar-link-mobile" href="/transactions">Transactions</a>
        <a class="navbar-link-mobile" href="/price-alerts">Alerts</a>
        <a class="navbar-link-mobile" href="/user">My Account</a>
        <a class="navbar-link-mobile text-amber-300 font-semibold" href="/billing">
            <i class="fas fa-star text-xs mr-1" aria-hidden="true"></i>Upgrade
        </a>
        <form method="post" action="/auth/logout" class="block">
            <button type="submit" class="navbar-link-mobile bg-transparent border-0 cursor-pointer p-0 w-full text-left">Logout</button>
        </form>
        {{else}}
        <a class="navbar-link-mobile navbar-login-link" href="/auth/login">Login</a>
        <a class="navbar-link-mobile" href="/user/create">Create Account</a>
        {{/if}}
        <a class="navbar-link-mobile" href="/guides/getting-started">
            <i class="fas fa-circle-question text-sm mr-1" aria-hidden="true"></i>Getting Started
        </a>
    </div>
</nav>
<div id="response-message" class="response-message bg-{{#if toast }}{{ toast.status }}{{else}}info{{/if}} hidden" role="alert">
    <div class="toast-body">
        <div class="toast-icon">
            {{#if (eq toast.status 'success')}}
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            {{else if (eq toast.status 'error')}}
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            {{else if (eq toast.status 'warning')}}
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            {{else}}
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            {{/if}}
        </div>
        <span class="toast-text">{{toast.message}}</span>
        <button class="toast-close" id="toast-close-btn" aria-label="Close notification">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
    </div>
    <div class="toast-progress"><div class="toast-progress-bar" id="toast-progress-bar"></div></div>
</div>
{{#if welcome}}
<div class="welcome-banner" role="status">
    <h2>Welcome to I Want My MTG!</h2>
    <p>Your account is ready. Start by browsing sets to find cards you own, or import your whole collection at once if you already have a list.</p>
    <div class="flex flex-wrap gap-2 mt-3">
        <a href="/sets" class="btn btn-primary text-sm px-3 py-1.5">Browse Sets</a>
        <a href="/inventory/import-export-guide" class="btn btn-secondary text-sm px-3 py-1.5">Import from CSV</a>
        <a href="/guides/getting-started" class="btn btn-ghost text-sm px-3 py-1.5">Getting Started Guide</a>
        <a href="/billing" class="btn text-sm px-3 py-1.5 bg-amber-500 hover:bg-amber-400 text-midnight-950 font-semibold">
            <i class="fas fa-star text-xs mr-1" aria-hidden="true"></i>Subscribe
        </a>
    </div>
</div>
{{/if}}

<script src="/public/js/toast.js?v={{assetVersion}}" defer></script>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const closeBtn = document.getElementById("toast-close-btn");
        if (closeBtn) {
            closeBtn.addEventListener("click", function () {
                if (typeof window.dismissToast === 'function') window.dismissToast();
            });
        }

        const message = document.getElementById("response-message");
        if (message) {
            const toastText = message.querySelector(".toast-text");
            if (toastText && toastText.textContent.trim().length > 0) {
                if (typeof window.showToast === 'function') {
                    // Extract current status from bg- class for proper duration
                    var status = 'info';
                    if (message.classList.contains('bg-success')) status = 'success';
                    else if (message.classList.contains('bg-error')) status = 'error';
                    else if (message.classList.contains('bg-warning')) status = 'warning';
                    window.showToast(toastText.textContent.trim(), status);
                }
            }
        }

        const menuBtn = document.getElementById("mobile-menu-button");
        menuBtn.addEventListener("click", () => {
            const menu = document.getElementById("mobile-menu");
            const isOpen = menu.classList.toggle("hidden") === false;
            menuBtn.setAttribute("aria-expanded", String(isOpen));
            menuBtn.setAttribute("aria-label", isOpen ? "Close navigation menu" : "Open navigation menu");
        });

        function toggleTheme() {
            const isDark = document.documentElement.classList.toggle("dark");
            localStorage.setItem("theme", isDark ? "dark" : "light");
        }

        // Set returnUrl on login links so user returns to current page after login
        var currentPath = window.location.pathname + window.location.search;
        if (currentPath && window.location.pathname !== '/auth/login') {
            document.querySelectorAll('.navbar-login-link').forEach(function(link) {
                link.href = '/auth/login?returnUrl=' + encodeURIComponent(currentPath);
            });
        }

        // Desktop theme toggle
        const desktopToggle = document.getElementById("theme-toggle");
        if (desktopToggle) {
            desktopToggle.addEventListener("click", toggleTheme);
        }

        // Mobile theme toggle
        const mobileToggle = document.getElementById("theme-toggle-mobile");
        if (mobileToggle) {
            mobileToggle.addEventListener("click", toggleTheme);
        }
    });
</script>
