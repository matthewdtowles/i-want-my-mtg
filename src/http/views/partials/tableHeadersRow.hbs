{{~!--
  Table header row - renders sortable or static headers based on presence of href.

  Parameters:
    tableHeadersRow.headers - array of { text, subtitle?, classes?: string[], href?, ascend? }
                              If href is present, renders as sortableHeader; otherwise tableHeader.
--~}}
<tr class="table-header-row">
    {{#each tableHeadersRow.headers as |header|}}
    {{#if header.href}}
    {{>sortableHeader header=header}}
    {{else}}
    {{>tableHeader header=header}}
    {{/if}}
    {{/each}}
</tr>