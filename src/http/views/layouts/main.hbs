<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    {{#if metaDescription}}
    <meta name="description" content="{{metaDescription}}">
    {{/if}}
    {{#if indexable}}
    <meta name="robots" content="index, follow">
    {{else}}
    <meta name="robots" content="noindex">
    {{/if}}
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com">
    <link rel="dns-prefetch" href="https://cards.scryfall.io">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cards.scryfall.io" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    {{#if lcpImageUrl}}
    <link rel="preload" href="{{lcpImageUrl}}" as="image" fetchpriority="high" />
    {{/if}}
    <link rel="preload" href="/public/css/tailwind.css?v={{assetVersion}}" as="style" />
    <link rel="preload" href="/public/css/app.css?v={{assetVersion}}" as="style" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <link href="/public/css/tailwind.css?v={{assetVersion}}" rel="stylesheet" type="text/css" />
    <link href="/public/css/app.css?v={{assetVersion}}" rel="stylesheet" type="text/css" />
    <link href="https://cdn.jsdelivr.net/npm/keyrune@3.18.0/css/keyrune.css" rel="stylesheet" type="text/css" media="print" onload="this.media='all'" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/fontawesome.min.css" rel="stylesheet" media="print" onload="this.media='all'" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/solid.min.css" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
        <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
        <link href="https://cdn.jsdelivr.net/npm/keyrune@3.18.0/css/keyrune.css" rel="stylesheet" />
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/fontawesome.min.css" rel="stylesheet" />
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/solid.min.css" rel="stylesheet" />
    </noscript>
    <script>
        (function() {
            var theme = localStorage.getItem('theme');
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (theme === 'dark' || (!theme && prefersDark)) {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>
</head>

<body class="bg-gray-50 dark:bg-midnight-950 font-body text-gray-900 dark:text-gray-100 min-h-screen flex flex-col">
    <header>
        {{>navbar}}
        {{>breadcrumbs}}
    </header>
    <main class="text-sm sm:text-base md:text-lg lg:text-xl flex-1">
        {{{body}}}
    </main>
    <footer>
        {{>footer}}
    </footer>

    <template id="tpl-quantity-form">
        <form class="quantity-form">
            <input type="hidden" name="cardId" />
            <button type="button" class="increment-quantity hover:text-purple-400 active:text-purple-600">+</button>
            <input type="number" name="quantity-owned" class="quantity-owned" aria-label="Quantity owned" />
            <input type="hidden" name="isFoil" />
            <button type="button" class="decrement-quantity hover:text-red-400 active:text-red-600">-</button>
        </form>
    </template>

    <template id="tpl-delete-inventory">
        <form class="delete-inventory-form">
            <input type="hidden" name="card-id" />
            <input type="hidden" name="isFoil" />
            <button type="button" class="delete-inventory-button">
                <i class="fas fa-trash-alt"></i>
            </button>
        </form>
    </template>

    <template id="tpl-transaction-row">
        <tr class="table-row">
            <td class="table-cell pl-2 text-gray-500 dark:text-gray-400 whitespace-nowrap">
                <span class="tx-display"></span>
                <input type="date" class="tx-edit hidden w-28 text-sm border border-gray-300 dark:border-midnight-500 rounded px-1 py-0.5 bg-white dark:bg-midnight-700 text-gray-700 dark:text-gray-200" data-field="date" />
            </td>
            <td class="table-cell">
                <span class="tx-type-buy inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 dark:bg-teal-900/40 dark:text-teal-300">BUY</span>
                <span class="tx-type-sell hidden inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-hotpink-100 text-hotpink-700 dark:bg-hotpink-700/30 dark:text-hotpink-300">SELL</span>
            </td>
            <td class="table-cell">
                <a class="tx-card-link card-name-link hidden"></a>
                <span class="tx-card-text"></span>
                <span class="tx-foil-badge foil-badge hidden">Foil</span>
                <span class="tx-set-code text-gray-400 dark:text-gray-500 text-xs hidden"></span>
            </td>
            <td class="table-cell">
                <span class="tx-display"></span>
                <input type="number" class="tx-edit hidden w-16 text-sm border border-gray-300 dark:border-midnight-500 rounded px-1 py-0.5 bg-white dark:bg-midnight-700 text-gray-700 dark:text-gray-200" data-field="quantity" min="1" step="1" />
            </td>
            <td class="table-cell font-mono">
                <span class="tx-display"></span>
                <input type="number" class="tx-edit hidden w-20 text-sm border border-gray-300 dark:border-midnight-500 rounded px-1 py-0.5 bg-white dark:bg-midnight-700 text-gray-700 dark:text-gray-200 font-mono" data-field="pricePerUnit" min="0" step="0.01" />
            </td>
            <td class="table-cell font-mono">
                <span class="tx-total"></span>
            </td>
            <td class="table-cell pr-2 tx-actions-cell">
                <span class="tx-editable-actions tx-display inline-flex gap-1 hidden">
                    <button type="button" class="edit-transaction-button text-gray-400 hover:text-teal-500 dark:hover:text-teal-400" title="Edit"><i class="fas fa-pencil-alt"></i></button>
                    <button type="button" class="delete-transaction-button text-gray-400 hover:text-red-500 dark:hover:text-red-400"><i class="fas fa-trash-alt"></i></button>
                </span>
                <span class="tx-editable-edit tx-edit hidden inline-flex gap-1">
                    <button type="button" class="save-transaction-button text-gray-400 hover:text-teal-500 dark:hover:text-teal-400" title="Save"><i class="fas fa-check"></i></button>
                    <button type="button" class="cancel-edit-button text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" title="Cancel"><i class="fas fa-times"></i></button>
                </span>
                <span class="tx-locked-icon hidden text-gray-300 dark:text-gray-600" title="Locked after 24 hours"><i class="fas fa-lock text-xs"></i></span>
            </td>
        </tr>
    </template>

    <script src="/public/js/searchSuggest.js?v={{assetVersion}}" defer></script>
    <script src="/public/js/prefetch.js?v={{assetVersion}}" defer></script>
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/sw.js').catch(function () {});
            });
        }
    </script>
</body>

</html>
