<section class='border border-gray-200 dark:border-midnight-700 rounded-xl sm:m-0 md:m-4'>
    <section class='text-center bg-teal-50 dark:bg-midnight-900 mb-4 rounded-t-lg py-4'>
        <h1 class='page-title'>Blog</h1>
        <p class='text-sm text-gray-500 dark:text-gray-400 mt-1'>Guides, market notes, and
            product updates for MTG collectors</p>
    </section>
    <div class='content-wrapper py-6 px-4'>
        <div class='max-w-3xl mx-auto space-y-4'>
            {{#each posts}}
                <a
                    href='/blog/{{this.slug}}'
                    class='block border border-gray-200 dark:border-midnight-700 rounded-xl p-4 transition-colors hover:border-teal-500 dark:hover:border-teal-500'
                >
                    <h2 class='text-lg font-semibold text-gray-900 dark:text-gray-100'>{{this.title}}</h2>
                    <time
                        datetime='{{this.date}}'
                        class='text-xs text-gray-500 dark:text-gray-400'
                    >{{this.date}}</time>
                    <p class='text-sm text-gray-600 dark:text-gray-400 mt-1'>{{this.description}}</p>
                </a>
            {{else}}
                <p class='text-center text-sm text-gray-500 dark:text-gray-400 py-8'>No posts yet.
                    Check back soon.</p>
            {{/each}}
        </div>
    </div>
</section>
