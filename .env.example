APP_NAME=i-want-my-mtg
DB_HOST=redacted
DB_PORT=redacted
DB_USERNAME=redacted
DB_PASSWORD=redacted
DB_NAME=redacted
NODE_ENV=dev
SCRY_LOG=debug
TIMING_ENABLED=false
JWT_SECRET=redacted
GITHUB_TOKEN=redacted
DEBUG_MODE=1
LOG_FORMAT=json

# DOCKER - PostgreSQL expects these exact names
POSTGRES_DB=redacted
POSTGRES_USER=redacted
POSTGRES_PASSWORD=redacted
DATABASE_URL=postgresql://user:pwd@postgres:0000/postgres_db

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=000
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@iwantmymtg.net
APP_URL=https://iwantmymtg.net

# Price Alert Processing (generate with: ./scripts/gen-api-key.sh)
INTERNAL_API_KEY=redacted

# Portfolio Summary
PORTFOLIO_REFRESH_MAX_DAILY=3
PORTFOLIO_REFRESH_COOLDOWN_MINUTES=60

# TCGPlayer Affiliate (Impact). Set to the partner link Impact gave you —
# either a shortlink (https://partner.tcgplayer.com/PzKzOM) or a full deep link
# (https://partner.tcgplayer.com/c/{partnerId}/{campaignId}/{creativeId}).
# Leave blank in dev; buy buttons will link to raw TCGPlayer URLs (no attribution).
TCGPLAYER_AFFILIATE_URL=

# Stripe billing. Leave blank in dev — billing endpoints will 500 until configured.
# Create one product with a monthly and annual recurring price in the Stripe dashboard
# and paste the price IDs below. Webhook secret is printed by `stripe listen` locally,
# or taken from the endpoint config in the Stripe dashboard in prod.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Optional overrides — default to ${APP_URL}/billing/success and /billing/canceled.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
