{{~!--
  Renders mana cost symbols using the mana-font icon set.

  Parameters:
    card.manaCost — array of { symbol: string, isHalf: boolean, sep: string }
                    Each entry is either a mana symbol or a separator.
--~}}
<span class="mana-cost">
    {{#if card.manaCost}}
    {{#each card.manaCost}}
    {{#if this.symbol}}
    <i class="ms ms-cost ms-shadow ms-{{this.symbol}} {{#if this.isHalf}}ms-half{{/if}}"></i>
    {{else}}
    <span class="mana-sep">{{this.sep}}</span>
    {{/if}}
    {{/each}}
    {{/if}}
</span>