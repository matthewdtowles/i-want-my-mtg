{{~!--
  Sealed products section for set detail page.
  Loaded via AJAX from /api/v1/sets/:code/sealed-products

  Parameters:
    setCode - the set code to fetch sealed products for
--~}}
<section id="sealed-products-section" class="mt-6" data-set-code="{{setCode}}">
    <h2 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-3">
        <svg class="w-5 h-5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
        Sealed Products
    </h2>
    <div id="sealed-products-list" class="text-sm text-gray-500 dark:text-gray-400">
        Loading sealed products...
    </div>
</section>
