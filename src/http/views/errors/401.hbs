<div class="text-center py-16 px-4 max-w-xl mx-auto">
    <div class="font-display text-8xl font-bold text-teal-500 dark:text-teal-400 mb-4">401</div>
    <div class="text-2xl font-semibold text-gray-800 dark:text-gray-200 mb-3">Sign In Required</div>
    <div class="text-base text-gray-500 dark:text-gray-400 mb-8">
        {{#if toast}}
            {{toast.message}}
        {{else}}
            This page is only available to signed-in users. Sign in to continue, or create a free account to get started.
        {{/if}}
    </div>
    <div class="flex gap-4 justify-center flex-wrap">
        <a href="/auth/login{{#if returnUrl}}?returnUrl={{encodeURIComponent returnUrl}}{{/if}}" class="btn btn-primary">Sign In</a>
        <a href="/user/create" class="btn btn-secondary">Create Account</a>
        <a href="/" class="btn btn-secondary">Go Home</a>
    </div>
</div>
