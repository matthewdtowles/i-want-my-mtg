{{~!--
  Stat card showing a label/value pair in a small box.

  Parameters:
    label      - display label (e.g. "Total Cards")
    value      - display value (e.g. "$123.45")
    valueClass - optional extra CSS class on the value span
    highlight  - if truthy, applies highlighted style
    metricHint - optional hint text shown as a first-visit tooltip via data-metric-hint
--~}}
<div class="stat-card{{#if highlight}} stat-card-highlight{{/if}}"{{#if metricHint}} data-metric-hint="{{metricHint}}"{{/if}}>
    <span class="stat-label">{{label}}</span>
    <span class="stat-value{{#if valueClass}} {{valueClass}}{{/if}}">{{value}}</span>
</div>
