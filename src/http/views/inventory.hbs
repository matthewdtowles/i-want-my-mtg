{{#if hasInventory}}
<section class="border border-gray-200 dark:border-midnight-700 rounded-2xl sm:m-0 md:m-4 overflow-hidden">
    <section class="app-page-header mb-4">
        <div class="app-page-header-bg" aria-hidden="true"></div>
        <div class="app-page-header-inner">
            <h1 class="app-page-title font-display">{{this.username}}'s Inventory</h1>
            <p class="app-page-sub">Your collection at a glance.</p>
        </div>

        <div class="relative max-w-3xl mx-auto px-4 pb-6">
            <div class="app-stat-tile app-stat-tile--featured mb-3">
                <span class="app-stat-tile-label">Collection Value</span>
                <span class="app-stat-tile-value">{{this.ownedValue}}</span>
            </div>
            <div class="grid grid-cols-2 gap-3 mb-4">
                <div class="app-stat-tile">
                    <span class="app-stat-tile-label">Total Cards</span>
                    <span class="app-stat-tile-value">{{this.ownedTotal}}</span>
                </div>
                <div class="app-stat-tile">
                    <span class="app-stat-tile-label">Completion</span>
                    <div class="app-stat-tile-value">{{>completionRate}}</div>
                </div>
            </div>

            <div class="flex justify-center gap-2 mb-4">
                <a href="/portfolio" class="btn btn-secondary text-sm px-3 py-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
                    </svg>
                    Portfolio
                </a>
                <a href="/transactions" class="btn btn-secondary text-sm px-3 py-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Transactions
                </a>
            </div>

            <div class="action-card">
                <span class="action-card-label">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                    </svg>
                    Import or Export Your Collection
                </span>
                <div class="flex flex-wrap gap-2 justify-center items-center">
                    <a href="/inventory/export" class="btn btn-primary text-sm px-3 py-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                        Export CSV
                    </a>
                    <label for="import-cards-file" class="btn btn-secondary text-sm px-3 py-1.5 cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Import Cards
                    </label>
                    <label for="import-sets-file" class="btn btn-secondary text-sm px-3 py-1.5 cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Import Sets
                    </label>
                </div>
                <p class="mt-3 pt-2 border-t border-gray-200 dark:border-midnight-600 text-xs text-center">
                    <a href="/inventory/import-export-guide" class="text-teal-600 dark:text-teal-400 hover:underline font-medium">Import & Export Guide</a>
                </p>
            </div>
        </div>

        <form id="import-cards-form" method="POST" action="/inventory/import/cards" enctype="multipart/form-data" class="hidden">
            <input id="import-cards-file" type="file" name="file" accept=".csv" onchange="this.form.submit()" />
        </form>
        <form id="import-sets-form" method="POST" action="/inventory/import/sets" enctype="multipart/form-data" class="hidden">
            <input id="import-sets-file" type="file" name="file" accept=".csv" onchange="this.form.submit()" />
        </form>
    </section>
    <div id="inventory-list-ajax" class="content-wrapper">
        <div class="flex items-center gap-2">
            <div class="flex-1">
                {{>filter}}
            </div>
            <a href="{{baseOnlyToggle.url}}"
               class="btn {{#if baseOnlyToggle.isBaseOnly}} btn-secondary {{else}} btn-primary {{/if}}
                      whitespace-nowrap h-[42px] flex items-center justify-center flex-shrink-0 mb-4
                      {{#unless baseOnlyToggle.visible}} hidden{{/unless}}">
                {{baseOnlyToggle.text}}
            </a>
        </div>
        <div id="filter-results">
            {{#if cards.length}}
            <div class="table-wrapper">
            <table class="table-container w-full">
                <thead>{{>tableHeadersRow}}</thead>
                <tbody>
                    {{#each cards as |card|}}
                    <tr class="table-row">
                        <td class="table-cell">{{>cardsOwned card=card}}</td>
                        <td class="table-cell">
                            {{>cardLink url=card.url name=card.name imgSrc=card.imgSrc item=card}}
                        </td>
                        <td class="table-cell">
                            <a href="/sets/{{card.setCode}}" class="table-link">
                                <i class="ss ss-{{card.setCode}} ss-{{toLowerCase card.rarity}} ss-fw"></i>
                                {{toUpperCase card.setCode}}
                            </a>
                            <a href="/inventory/sets/{{card.setCode}}" class="binder-link" title="Open binder">
                                <i class="fas fa-book-open"></i>
                            </a>
                        </td>
                        <td class="table-cell">
                            <span class="price-{{#if card.isFoil}}foil{{else}}normal{{/if}}">
                                {{card.priceValue}}
                            </span>
                        </td>
                        <td class="table-cell delete-inventory-entry xs-hide">
                            {{>deleteInventoryEntry card=card}}
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            </div>
            {{else}}
            {{>emptyState icon="search" message="No cards match your current filters" hint="Try a different search term or adjust your filters." buttonHref="/inventory" buttonText="Show All Cards"}}
            {{/if}}
        </div>
    </div>
    {{>pagination hasItems=this.cards.length}}
</section>

{{else}}
<section class="border border-gray-200 dark:border-midnight-700 rounded-2xl sm:m-0 md:m-4 overflow-hidden">
    <div class="app-page-header rounded-2xl pb-5">
        <div class="app-page-header-bg" aria-hidden="true"></div>
        <div class="relative text-center pt-8 pb-2 px-4">
            <i class="fas fa-box-open text-5xl text-teal-300 dark:text-teal-600 mb-4"></i>
            <h3 class="page-title mt-4">Your collection is empty</h3>
            <p class="text-gray-500 dark:text-gray-400 mt-2 max-w-md mx-auto">
                Add cards one at a time by browsing sets, or import your whole collection at once from a CSV file.
            </p>
            <div class="flex flex-wrap justify-center gap-2 mt-6">
                <a href="/sets" class="btn btn-primary">Browse Sets</a>
                <a href="/inventory/import-export-guide" class="btn btn-secondary">Import from CSV</a>
            </div>
            <p class="mt-4 text-xs text-gray-500 dark:text-gray-400">
                New here? <a href="/guides/getting-started" class="text-teal-600 dark:text-teal-400 hover:underline font-medium">Read the Getting Started guide</a>
            </p>
        </div>
        <div class="relative max-w-md mx-auto px-4 mt-6">
            <div class="action-card">
                <span class="action-card-label">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                    </svg>
                    Import Your Collection
                </span>
                <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Already have a list? Import cards or entire sets from a CSV file.</p>
                <div class="flex flex-wrap gap-2 justify-center items-center">
                    <label for="import-cards-file-empty" class="btn btn-secondary text-sm px-3 py-1.5 cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Import Cards
                    </label>
                    <label for="import-sets-file-empty" class="btn btn-secondary text-sm px-3 py-1.5 cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Import Sets
                    </label>
                </div>
                <p class="mt-3 pt-2 border-t border-gray-200 dark:border-midnight-600 text-xs text-center">
                    <a href="/inventory/import-export-guide" class="text-teal-600 dark:text-teal-400 hover:underline font-medium">Import &amp; Export Guide</a>
                </p>
            </div>
        </div>
        <form method="POST" action="/inventory/import/cards" enctype="multipart/form-data" class="hidden">
            <input id="import-cards-file-empty" type="file" name="file" accept=".csv" onchange="this.form.submit()" />
        </form>
        <form method="POST" action="/inventory/import/sets" enctype="multipart/form-data" class="hidden">
            <input id="import-sets-file-empty" type="file" name="file" accept=".csv" onchange="this.form.submit()" />
        </form>
    </div>
</section>
{{/if}}

<script src="/public/js/updateInventory.js?v={{assetVersion}}" defer></script>
<script src="/public/js/ajaxUtils.js?v={{assetVersion}}" defer></script>
<script src="/public/js/inventoryListAjax.js?v={{assetVersion}}" defer></script>
<script src="/public/js/tooltipManager.js?v={{assetVersion}}" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    new TooltipManager({
        triggerSelector: '.import-export-tooltip-trigger',
        tooltipSelector: '.import-export-tooltip',
    });
});
</script>
