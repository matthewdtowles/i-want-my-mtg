<section class='border border-gray-200 dark:border-midnight-700 rounded-xl sm:m-0 md:m-4'>
    <section class='text-center bg-teal-50 dark:bg-midnight-900 mb-4 rounded-t-lg py-6 px-4'>
        <h1 class='page-title'>{{post.title}}</h1>
        <time
            datetime='{{post.date}}'
            class='text-xs text-gray-500 dark:text-gray-400'
        >{{post.date}}</time>
    </section>
    <div class='content-wrapper py-6 px-4'>
        <article class='blog-prose max-w-3xl mx-auto'>
            {{{post.html}}}
        </article>
        <div class='max-w-3xl mx-auto mt-8'>
            <a
                href='/blog'
                class='text-sm text-teal-600 dark:text-teal-400 underline'
            >&larr; Back to all posts</a>
        </div>
    </div>
</section>
