<div class='settings-container'>
    <h1 class='page-title'>Subscription</h1>

    {{#if notice}}
        <div class='rounded border p-3 mb-4
            {{#if (eq notice.type "success")}}border-green-500 bg-green-50 text-green-800 dark:bg-green-900/30 dark:text-green-200{{/if}}
            {{#if (eq notice.type "info")}}border-blue-500 bg-blue-50 text-blue-800 dark:bg-blue-900/30 dark:text-blue-200{{/if}}
            {{#if (eq notice.type "error")}}border-red-500 bg-red-50 text-red-800 dark:bg-red-900/30 dark:text-red-200{{/if}}'>
            {{notice.message}}
        </div>
    {{/if}}

    {{#if subscription.isActive}}
        <div class='section-container'>
            <h3 class='page-subtitle'>Your Plan</h3>
            <p class='text-sm text-gray-600 dark:text-gray-400 mb-2'>
                <strong class='capitalize'>{{subscription.plan}}</strong> &middot;
                {{#if subscription.cancelAtPeriodEnd}}
                    Ends <strong>{{subscription.currentPeriodEnd}}</strong>. You can resume any time through Manage Billing.
                {{else if subscription.currentPeriodEnd}}
                    Renews <strong>{{subscription.currentPeriodEnd}}</strong>. Thanks for supporting I Want My MTG!
                {{else}}
                    Active. Thanks for supporting I Want My MTG!
                {{/if}}
            </p>
        </div>

        <div class='section-container'>
            <h3 class='page-subtitle'>Manage Billing</h3>
            <p class='text-sm text-gray-600 dark:text-gray-400 mb-3'>
                Switch plans, update your payment method, download invoices, or cancel your subscription.
            </p>
            <form method='POST' action='/billing/portal'>
                <button class='btn btn-primary' type='submit'>Open Billing Portal</button>
            </form>
        </div>
    {{else}}
        <div class='section-container'>
            <h3 class='page-subtitle'>No Active Subscription</h3>
            <p class='text-sm text-gray-600 dark:text-gray-400 mb-3'>
                You're on the Free plan. Upgrade to Premium to unlock unlimited alerts, full transaction history, P&amp;L tracking, and advanced analytics.
            </p>
            <a class='btn btn-primary' href='/pricing'>
                <i class='fas fa-star text-xs mr-1' aria-hidden='true'></i>View Plans &amp; Upgrade
            </a>
        </div>
    {{/if}}

    <div class='section-container'>
        <a class='btn btn-ghost' href='/user'>Back to User Settings</a>
    </div>
</div>
