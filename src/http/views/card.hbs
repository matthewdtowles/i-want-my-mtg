<link href="/public/css/mana.css?v={{assetVersion}}" rel="stylesheet" type="text/css" />
<section class="content-wrapper">
    <section class="card-info flex flex-col md:flex-row section-container">

        <section class="md:w-1/4 flex-shrink-0 mb-4 md:mb-6">
            <div class="card-image-wrapper" id="card-image-wrapper" role="button" tabindex="0" aria-label="View enlarged image of {{card.name}}">
                <img class="card-image" src="{{card.imgSrc}}" alt="{{card.name}} - ({{card.setCode}})" width="244" height="340" fetchpriority="high" />
            </div>
        </section>

        <section class="play-info flex-1 min-w-0 md:pl-6">

            <header class="mb-6">
                <h1 class="card-title">
                    {{#if card.flavorName}}
                    <span>{{card.flavorName}}</span>
                    {{else}}
                    <span>{{card.name}}</span>
                    {{/if}}
                    <span class="ml-1">{{>manaCost card=card}}</span>
                </h1>
                {{#if card.flavorName}}
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">({{card.name}})</p>
                {{/if}}
                <div class="flex items-center flex-wrap gap-2 mt-1">
                    <i class="ss ss-{{card.setCode}} ss-{{toLowerCase card.rarity}} ss-2x"></i>
                    <a class="table-link text-base" href="/sets/{{card.setCode}}">{{toUpperCase card.setCode}} {{card.setName}}</a>
                    {{>tags item=card}}
                </div>
            </header>

            <section class="mb-5 pb-5 border-b border-gray-100 dark:border-midnight-700">
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-1">{{card.type}}</p>
                <p class="text-base text-gray-800 dark:text-gray-200 leading-relaxed whitespace-pre-line">{{card.oracleText}}</p>
            </section>

            <div class="flex flex-wrap gap-x-6 gap-y-1 text-sm text-gray-500 dark:text-gray-400 mb-5 pb-5 border-b border-gray-100 dark:border-midnight-700">
                <span>{{capitalize card.rarity}}</span>
                <span>#{{card.number}}</span>
                <span>Illustrated by {{card.artist}}</span>
            </div>

            <section class="card-legalities">
                <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-3">Legalities</h2>
                <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                    {{#each card.legalities as |legality|}}
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-600 dark:text-gray-400">{{capitalize legality.format}}</span>
                        {{#if (eq legality.status 'legal')}}
                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 dark:bg-teal-900/40 dark:text-teal-300">{{capitalize legality.status}}</span>
                        {{else if (eq legality.status 'banned')}}
                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-hotpink-100 text-hotpink-700 dark:bg-hotpink-700/30 dark:text-hotpink-300">{{capitalize legality.status}}</span>
                        {{else if (eq legality.status 'restricted')}}
                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900/40 dark:text-purple-300">{{capitalize legality.status}}</span>
                        {{else}}
                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">{{capitalize legality.status}}</span>
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
            </section>
        </section>

        <section class="price-info md:w-1/4 flex-shrink-0 md:pl-6 mb-4 md:mb-0 border-none min-w-0">
            <section class="subsection-container">
                <h2 class="section-title">Pricing</h2>
                <div class="grid {{#if card.hasNormal}}{{#if card.hasFoil}}grid-cols-2{{else}}grid-cols-1{{/if}}{{else}}grid-cols-1{{/if}} gap-2 mb-3">
                    {{#if card.hasNormal}}
                    <div class="price-tile border-teal-300 dark:border-teal-600 bg-white dark:bg-midnight-800">
                        <h3 class="font-semibold text-teal-700 dark:text-teal-300 text-xs uppercase tracking-wide mb-1">Normal</h3>
                        <div class="price-tile-value font-bold text-gray-900 dark:text-gray-100 font-mono">
                            {{card.normalPrice}}
                        </div>
                        {{#if card.priceChangeWeekly}}
                        <span class="price-change price-change-{{card.priceChangeWeeklySign}} text-xs">{{card.priceChangeWeekly}}</span>
                        {{/if}}
                    </div>
                    {{/if}}
                    {{#if card.hasFoil}}
                    <div class="price-tile border-purple-300 dark:border-purple-600 bg-purple-50 dark:bg-purple-950/30">
                        <h3 class="font-semibold text-purple-700 dark:text-purple-300 text-xs uppercase tracking-wide mb-1">Foil</h3>
                        <div class="price-tile-value font-bold text-purple-900 dark:text-purple-200 font-mono">
                            {{card.foilPrice}}
                        </div>
                        {{#if card.foilPriceChangeWeekly}}
                        <span class="price-change price-change-{{card.foilPriceChangeWeeklySign}} text-xs">{{card.foilPriceChangeWeekly}}</span>
                        {{/if}}
                    </div>
                    {{/if}}
                </div>
                {{#if card.purchaseUrlTcgplayer}}
                {{>buyOnTcgplayer url=card.purchaseUrlTcgplayer label="Buy on TCGPlayer"}}
                {{/if}}
                {{#if card.purchaseUrlTcgplayerEtched}}
                {{>buyOnTcgplayer url=card.purchaseUrlTcgplayerEtched label="Buy Etched on TCGPlayer"}}
                {{/if}}
                <section class="inventory-info">
                    {{>invStepper card=card}}
                </section>

                {{>costBasis}}

                {{#if authenticated}}
                {{#if untrackedNormal}}
                <div id="sync-normal" class="mt-3 p-3 rounded-lg border border-amber-200 dark:border-amber-700/50 bg-amber-50 dark:bg-amber-900/20">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-amber-800 dark:text-amber-300">
                                <i class="fas fa-info-circle mr-1"></i>
                                <strong>{{untrackedNormal}}</strong> untracked normal {{#if (eq untrackedNormal 1)}}copy{{else}}copies{{/if}}
                            </p>
                            <p class="text-xs text-amber-600 dark:text-amber-400 mt-0.5">Record as buy to track cost basis</p>
                        </div>
                        <button type="button" class="sync-inventory-button text-xs px-3 py-1.5 rounded bg-amber-500 hover:bg-amber-600 text-white font-medium"
                                data-card-id="{{card.cardId}}" data-quantity="{{untrackedNormal}}" data-is-foil="false"
                                data-price="{{card.normalPriceRaw}}">
                            Record
                        </button>
                    </div>
                </div>
                {{/if}}
                {{#if untrackedFoil}}
                <div id="sync-foil" class="mt-3 p-3 rounded-lg border border-amber-200 dark:border-amber-700/50 bg-amber-50 dark:bg-amber-900/20">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-amber-800 dark:text-amber-300">
                                <i class="fas fa-info-circle mr-1"></i>
                                <strong>{{untrackedFoil}}</strong> untracked foil {{#if (eq untrackedFoil 1)}}copy{{else}}copies{{/if}}
                            </p>
                            <p class="text-xs text-amber-600 dark:text-amber-400 mt-0.5">Record as buy to track cost basis</p>
                        </div>
                        <button type="button" class="sync-inventory-button text-xs px-3 py-1.5 rounded bg-amber-500 hover:bg-amber-600 text-white font-medium"
                                data-card-id="{{card.cardId}}" data-quantity="{{untrackedFoil}}" data-is-foil="true"
                                data-price="{{card.foilPriceRaw}}">
                            Record
                        </button>
                    </div>
                </div>
                {{/if}}
                {{/if}}

                {{>transactionForm}}
                {{>priceAlertForm}}
                {{>addToDeckForm}}

                <div class="mt-4" id="price-history-chart" data-card-id="{{card.cardId}}" data-chart-src="/public/js/priceHistoryChart.js?v={{assetVersion}}">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Price History</h3>
                        <div class="flex gap-1">
                            <button class="history-range-btn price-history-range active px-2 py-1 text-xs rounded" data-days="7">1w</button>
                            <button class="history-range-btn price-history-range px-2 py-1 text-xs rounded" data-days="30">30d</button>
                            <button class="history-range-btn price-history-range px-2 py-1 text-xs rounded" data-days="365">1y</button>
                            <button class="history-range-btn price-history-range px-2 py-1 text-xs rounded" data-days="">All</button>
                        </div>
                    </div>
                    <div id="card-price-legend" class="flex flex-wrap gap-x-4 gap-y-1 mb-2 text-xs"></div>
                    <div style="position: relative; height: 300px;">
                        <canvas id="price-history-canvas"></canvas>
                    </div>
                </div>
            </section>
        </section>
    </section>
    </section>

    {{#if otherPrintings.length}}
    <section class="section-container">
        <h2 class="section-title">Other Printings</h2>
        <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>
                {{>tableHeadersRow}}
            </thead>
            <tbody>
                {{#each otherPrintings as |p|}}
                <tr class="table-row">
                    <td class="table-cell set-icon"><i class="ss ss-{{p.setCode}}"></i></td>
                    <td class="table-cell">
                        {{>cardLink url=p.url name=p.name imgSrc=p.imgSrc item=p}}
                        <span> (<a class="table-link" href="/sets/{{p.setCode}}">{{toUpperCase p.setCode}}</a>)</span>
                    </td>
                    {{#if ../hasAnyNormalPrice}}
                    <td class="table-cell">
                        {{#if p.hasNormal}}
                        <span class="price-normal">{{p.normalPrice}}</span>
                        {{/if}}
                    </td>
                    {{/if}}
                    {{#if ../hasAnyFoilPrice}}
                    <td class="table-cell">
                        {{#if p.hasFoil}}
                        <span class="price-foil">{{p.foilPrice}}</span>
                        <span class="foil-badge xs-hide">Foil</span>
                        {{/if}}
                    </td>
                    {{/if}}
                </tr>
                {{/each}}
            </tbody>
        </table>
        </div>
        {{#if (gt pagination.totalPages 1)}}
        {{>pagination hasItems=otherPrintings.length}}
        {{/if}}
    </section>
    {{/if}}
</section>


<script src="/public/js/updateInventory.js?v={{assetVersion}}" defer></script>
<script src="/public/js/chartLoader.js?v={{assetVersion}}" defer></script>
<script src="/public/js/transactionForm.js?v={{assetVersion}}" defer></script>
<script src="/public/js/priceAlertForm.js?v={{assetVersion}}" defer></script>
<script src="/public/js/tooltipManager.js?v={{assetVersion}}" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    new TooltipManager({
        triggerSelector: '.cost-basis-tooltip-trigger',
        tooltipSelector: '.cost-basis-tooltip',
    });


});
</script>
