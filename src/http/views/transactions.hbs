{{#if hasTransactions}}
<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    <section class="text-center bg-teal-50 dark:bg-midnight-900 mb-4 rounded-t-lg py-4">
        <h1 class="page-title">{{this.username}}'s Transactions</h1>
        <p class="text-gray-700 dark:text-gray-300">Total Transactions: {{this.totalTransactions}}</p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">
            <i class="fas fa-info-circle mr-1"></i>Transactions can be edited or deleted within 24 hours of creation
        </p>
        <div class="flex justify-center gap-2 mt-2">
            <a href="/portfolio" class="btn btn-secondary text-sm px-3 py-1.5">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
                </svg>
                Portfolio
            </a>
            <a href="/transactions/export" class="btn btn-secondary text-sm px-3 py-1.5">
                <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Export CSV
            </a>
        </div>
    </section>
    <div id="transaction-list-ajax" class="content-wrapper">
        <div class="flex items-center gap-2">
            <div class="flex-1">{{>filter}}</div>
        </div>
        <div id="filter-results">
        <div class="table-wrapper">
        <table class="table-container w-full">
            <thead>
                <tr class="table-header-row">
                    <th class="table-header">Date</th>
                    <th class="table-header">Type</th>
                    <th class="table-header">Card</th>
                    <th class="table-header">Qty</th>
                    <th class="table-header">Price</th>
                    <th class="table-header">Total</th>
                    <th class="table-header tx-actions-cell"></th>
                </tr>
            </thead>
            <tbody>
                {{#each transactions as |tx|}}
                <tr class="table-row" data-transaction-id="{{tx.id}}" data-raw-price="{{tx.rawPricePerUnit}}" data-raw-fees="{{tx.rawFees}}" data-source="{{tx.source}}" data-notes="{{tx.notes}}">
                    <td class="table-cell text-gray-500 dark:text-gray-400 whitespace-nowrap">
                        <span class="tx-display">{{tx.date}}</span>
                        <input type="date" class="tx-edit hidden w-28 text-sm border border-gray-300 dark:border-midnight-500 rounded px-1 py-0.5 bg-white dark:bg-midnight-700 text-gray-700 dark:text-gray-200" data-field="date" value="{{tx.date}}" />
                    </td>
                    <td class="table-cell">
                        {{#if (eq tx.type 'BUY')}}
                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 dark:bg-teal-900/40 dark:text-teal-300">BUY</span>
                        {{else}}
                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-hotpink-100 text-hotpink-700 dark:bg-hotpink-700/30 dark:text-hotpink-300">SELL</span>
                        {{/if}}
                    </td>
                    <td class="table-cell">
                        {{#if tx.cardUrl}}
                        <a href="{{tx.cardUrl}}" class="card-name-link">{{tx.cardName}}</a>
                        {{else}}
                        {{tx.cardName}}
                        {{/if}}
                        {{#if tx.isFoil}}
                        <span class="foil-badge">Foil</span>
                        {{/if}}
                        {{#if tx.cardSetCode}}
                        <span class="text-gray-400 dark:text-gray-500 text-xs">({{toUpperCase tx.cardSetCode}})</span>
                        {{/if}}
                    </td>
                    <td class="table-cell">
                        <span class="tx-display">{{tx.quantity}}</span>
                        <input type="number" class="tx-edit hidden w-16 text-sm border border-gray-300 dark:border-midnight-500 rounded px-1 py-0.5 bg-white dark:bg-midnight-700 text-gray-700 dark:text-gray-200" data-field="quantity" value="{{tx.quantity}}" min="1" step="1" />
                    </td>
                    <td class="table-cell font-mono">
                        <span class="tx-display">{{tx.pricePerUnit}}</span>
                        <input type="number" class="tx-edit hidden w-20 text-sm border border-gray-300 dark:border-midnight-500 rounded px-1 py-0.5 bg-white dark:bg-midnight-700 text-gray-700 dark:text-gray-200 font-mono" data-field="pricePerUnit" value="{{tx.rawPricePerUnit}}" min="0" step="0.01" />
                    </td>
                    <td class="table-cell font-mono">
                        <span class="tx-total">{{tx.totalPrice}}</span>
                    </td>
                    <td class="table-cell tx-actions-cell">
                        {{#if tx.editable}}
                        <span class="tx-display inline-flex gap-1">
                            <button type="button" class="edit-transaction-button text-gray-400 hover:text-teal-500 dark:hover:text-teal-400" title="Edit">
                                <i class="fas fa-pencil-alt"></i>
                            </button>
                            <button type="button" class="delete-transaction-button text-gray-400 hover:text-red-500 dark:hover:text-red-400" data-transaction-id="{{tx.id}}">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </span>
                        <span class="tx-edit hidden inline-flex gap-1">
                            <button type="button" class="save-transaction-button text-gray-400 hover:text-teal-500 dark:hover:text-teal-400" title="Save">
                                <i class="fas fa-check"></i>
                            </button>
                            <button type="button" class="cancel-edit-button text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" title="Cancel">
                                <i class="fas fa-times"></i>
                            </button>
                        </span>
                        {{else}}
                        <span class="text-gray-300 dark:text-gray-600" title="Locked after 24 hours">
                            <i class="fas fa-lock text-xs"></i>
                        </span>
                        {{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        </div>
        </div>
    </div>
    {{>pagination hasItems=this.transactions.length}}
</section>

{{else}}
<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    <div class="text-center py-16 px-4">
        <i class="fas fa-receipt text-5xl text-teal-300 dark:text-teal-600 mb-4"></i>
        <h3 class="text-xl font-semibold text-gray-700 dark:text-gray-300 mt-4">No transactions yet</h3>
        <p class="text-gray-400 dark:text-gray-500 mt-2 max-w-md mx-auto">Record buy and sell transactions from card detail pages to track your profit & loss.</p>
        <a href="/inventory" class="btn btn-primary inline-block mt-6">Go to Inventory</a>
    </div>
</section>
{{/if}}

<script src="/public/js/ajaxUtils.js" defer></script>
<script src="/public/js/transactionListAjax.js" defer></script>