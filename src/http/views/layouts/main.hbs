<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    {{#if indexable}}
    <meta name="robots" content="index, follow">
    {{else}}
    <meta name="robots" content="noindex">
    {{/if}}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="//cdn.jsdelivr.net/npm/keyrune@latest/css/keyrune.css" rel="stylesheet" type="text/css" />
    <link href="/public/css/tailwind.css" rel="stylesheet" type="text/css" />
    <link href="/public/css/app.css" rel="stylesheet" type="text/css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet" >
    <script>
        (function() {
            var theme = localStorage.getItem('theme');
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (theme === 'dark' || (!theme && prefersDark)) {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>
</head>

<body class="bg-gray-50 dark:bg-midnight-950 font-body text-gray-900 dark:text-gray-100 min-h-screen flex flex-col">
    <header>
        {{>navbar}}
        {{>breadcrumbs}}
    </header>
    <main class="text-sm sm:text-base md:text-lg lg:text-xl flex-1">
        {{{body}}}
    </main>
    <footer>
        {{>footer}}
    </footer>

    <template id="tpl-quantity-form">
        <form class="quantity-form">
            <input type="hidden" name="cardId" />
            <button type="button" class="increment-quantity hover:text-purple-400 active:text-purple-600">+</button>
            <input type="number" name="quantity-owned" class="quantity-owned" />
            <input type="hidden" name="isFoil" />
            <button type="button" class="decrement-quantity hover:text-red-400 active:text-red-600">-</button>
        </form>
    </template>

    <template id="tpl-delete-inventory">
        <form class="delete-inventory-form">
            <input type="hidden" name="card-id" />
            <input type="hidden" name="isFoil" />
            <button type="button" class="delete-inventory-button">
                <i class="fas fa-trash-alt"></i>
            </button>
        </form>
    </template>

    <script src="/public/js/searchSuggest.js"></script>
</body>

</html>
