<section class="border border-gray-200 dark:border-midnight-600 rounded-lg sm:m-0 md:m-4">
    <section class="text-center bg-teal-50 dark:bg-midnight-900 mb-4 rounded-t-lg py-4">
        <h1 class="page-title">My Decks</h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm mt-1 max-w-md mx-auto">
            Build and track decks by format. Pick Freestyle to ignore format restrictions.
        </p>
    </section>

    <div class="content-wrapper">
        <section class="mb-8 rounded-lg border border-gray-200 dark:border-midnight-600 p-4">
            <h2 class="text-lg font-semibold mb-3">Create a new deck</h2>
            <form method="POST" action="/decks" class="flex flex-col sm:flex-row gap-3 items-stretch">
                <input type="text" name="name" required maxlength="120" placeholder="Deck name"
                    class="flex-1 px-3 py-2 border border-gray-300 dark:border-midnight-600 rounded bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100" />
                <select name="format"
                    class="px-3 py-2 border border-gray-300 dark:border-midnight-600 rounded bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100">
                    {{#each formats}}
                    <option value="{{this.value}}">{{this.label}}</option>
                    {{/each}}
                </select>
                <button type="submit" class="btn btn-primary">Create</button>
            </form>
        </section>

        {{#if hasDecks}}
        <div class="table-wrapper">
            <table class="table-container w-full">
                <thead>
                    <tr>
                        <th class="text-left">Name</th>
                        <th class="text-left">Format</th>
                        <th class="text-right">Main</th>
                        <th class="text-right">Side</th>
                        <th class="text-left">Updated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each decks}}
                    <tr>
                        <td><a href="/decks/{{this.id}}" class="table-link">{{this.name}}</a></td>
                        <td>{{this.formatLabel}}</td>
                        <td class="text-right">{{this.cardCount}}</td>
                        <td class="text-right">{{this.sideboardCount}}</td>
                        <td class="text-sm text-gray-500">{{this.updatedAt}}</td>
                        <td class="text-right">
                            <form method="POST" action="/decks/{{this.id}}/delete"
                                onsubmit="return confirm('Delete this deck?');" class="inline">
                                <button type="submit" class="text-red-600 hover:underline text-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="text-center py-16">
            <i class="fas fa-layer-group text-5xl text-teal-300 dark:text-teal-600 mb-4"></i>
            <h3 class="text-xl font-semibold">No decks yet</h3>
            <p class="text-gray-500 dark:text-gray-400 mt-2 max-w-md mx-auto">
                Create your first deck above to start tracking a build.
            </p>
        </div>
        {{/if}}
    </div>
</section>
