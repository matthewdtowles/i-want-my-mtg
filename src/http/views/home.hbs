<section class="relative overflow-hidden mb-6">
    <div class="absolute inset-0 bg-gradient-to-b from-gray-50/80 to-gray-50 dark:from-midnight-950/80 dark:to-midnight-950"></div>
    <div class="relative text-center py-12 px-4">
        <h1 class="font-display text-4xl md:text-5xl font-bold mb-4
                   bg-gradient-to-r from-purple-700 via-teal-500 to-purple-700
                   dark:from-purple-400 dark:via-teal-400 dark:to-purple-400
                   bg-clip-text text-transparent">
            I Want My MTG!
        </h1>
        <p class="text-base text-gray-600 dark:text-gray-400 mb-5 max-w-lg mx-auto">
            Your Magic: The Gathering collection tracker — know what you own, what it's worth, and what you've spent.
        </p>
        <div class="flex flex-wrap justify-center gap-4 mb-2">
            <div class="flex items-center gap-1.5 text-sm font-medium text-teal-700 dark:text-teal-300">
                <i class="fas fa-layer-group text-xs"></i>
                <span>Track cards &amp; sets you own</span>
            </div>
            <div class="flex items-center gap-1.5 text-sm font-medium text-purple-700 dark:text-purple-300">
                <i class="fas fa-chart-line text-xs"></i>
                <span>Watch your portfolio value</span>
            </div>
            <div class="flex items-center gap-1.5 text-sm font-medium text-hotpink-600 dark:text-hotpink-300">
                <i class="fas fa-receipt text-xs"></i>
                <span>Log buys, sells &amp; gains</span>
            </div>
        </div>
    </div>
</section>
<div class="mana-color-bar" aria-hidden="true">
    <span class="mana-w"></span>
    <span class="mana-u"></span>
    <span class="mana-b"></span>
    <span class="mana-r"></span>
    <span class="mana-g"></span>
</div>
{{>setList}}
