{{~!
  Inline price alert form on card detail page.

  Parameters:
    authenticated - boolean, only renders for logged-in users
    card          - { cardId }
~}}
{{#if authenticated}}
    <div
        id='price-alert-form-section'
        class='mt-4 border-t border-gray-200 dark:border-midnight-600 pt-4'
    >
        <div class='flex items-center justify-between mb-3'>
            <h4 class='text-sm font-semibold text-gray-700 dark:text-gray-300'>Price Alert</h4>
            <a
                href='/price-alerts'
                class='text-xs text-teal-600 dark:text-teal-400 hover:underline'
            >View All</a>
        </div>
        <form id='price-alert-form' class='space-y-3'>
            <input type='hidden' name='cardId' value='{{card.cardId}}' />

            <div class='grid grid-cols-2 gap-2'>
                <div>
                    <label class='text-xs text-gray-500 dark:text-gray-400 block mb-1'>Increase %</label>
                    <input
                        type='number'
                        name='increasePct'
                        placeholder='e.g. 10'
                        min='0'
                        step='1'
                        class='w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100'
                    />
                </div>
                <div>
                    <label class='text-xs text-gray-500 dark:text-gray-400 block mb-1'>Decrease %</label>
                    <input
                        type='number'
                        name='decreasePct'
                        placeholder='e.g. 10'
                        min='0'
                        step='1'
                        class='w-full px-2 py-1.5 text-sm rounded border border-gray-300 dark:border-midnight-600 bg-white dark:bg-midnight-800 text-gray-900 dark:text-gray-100'
                    />
                </div>
            </div>

            <div id='price-alert-form-message' class='hidden text-xs py-1'></div>

            <button type='submit' class='btn btn-primary w-full text-sm py-1.5'>
                Set Price Alert
            </button>
        </form>
    </div>
{{/if}}
