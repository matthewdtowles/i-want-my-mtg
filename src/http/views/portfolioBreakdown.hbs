<div class='content-wrapper py-6'>
    <div class='flex items-center justify-between mb-2 flex-wrap gap-3'>
        <div>
            <h1 class='page-title'>Portfolio Analytics</h1>
            <p class='page-subtitle'>Where your collection's value lives - by set, rarity, or card type.</p>
        </div>
        <a href='/portfolio' class='btn btn-ghost text-sm'>&larr; Back to Portfolio</a>
    </div>

    {{#if locked}}
        {{!-- Premium upsell for free users --}}
        <div class='section-container text-center py-12'>
            <div class='max-w-xl mx-auto'>
                <div class='inline-flex items-center justify-center w-14 h-14 rounded-full mb-4
                            bg-gradient-to-br from-teal-400 to-purple-500 text-white shadow-glow-teal'>
                    <svg class='w-7 h-7' fill='none' stroke='currentColor' stroke-width='2' viewBox='0 0 24 24'>
                        <path stroke-linecap='round' stroke-linejoin='round' d='M9 19V6l12-3v13M9 19c0 1.66-1.34 3-3 3s-3-1.34-3-3 1.34-3 3-3 3 1.34 3 3zm12-3c0 1.66-1.34 3-3 3s-3-1.34-3-3 1.34-3 3-3 3 1.34 3 3z'/>
                    </svg>
                </div>
                <h2 class='font-display font-bold text-xl text-gray-900 dark:text-white mb-2'>Advanced analytics is a Premium feature</h2>
                <p class='text-gray-600 dark:text-gray-400 mb-6 leading-relaxed'>
                    Break down your collection&rsquo;s value by set, rarity, or card type. See which slices of your collection are pulling the most weight - and where to look next.
                </p>

                <div class='grid grid-cols-3 gap-3 max-w-md mx-auto mb-8 text-left'>
                    <div class='p-3 rounded-lg bg-gray-50 dark:bg-midnight-800 border border-gray-200 dark:border-midnight-700'>
                        <div class='text-xs uppercase tracking-wider text-purple-600 dark:text-purple-400 font-semibold mb-1'>By Set</div>
                        <div class='text-xs text-gray-500 dark:text-gray-400'>Which sets dominate your collection value</div>
                    </div>
                    <div class='p-3 rounded-lg bg-gray-50 dark:bg-midnight-800 border border-gray-200 dark:border-midnight-700'>
                        <div class='text-xs uppercase tracking-wider text-purple-600 dark:text-purple-400 font-semibold mb-1'>By Rarity</div>
                        <div class='text-xs text-gray-500 dark:text-gray-400'>Mythics vs rares vs the rest</div>
                    </div>
                    <div class='p-3 rounded-lg bg-gray-50 dark:bg-midnight-800 border border-gray-200 dark:border-midnight-700'>
                        <div class='text-xs uppercase tracking-wider text-purple-600 dark:text-purple-400 font-semibold mb-1'>By Type</div>
                        <div class='text-xs text-gray-500 dark:text-gray-400'>Creatures, lands, artifacts, and beyond</div>
                    </div>
                </div>

                <div class='flex flex-wrap gap-3 justify-center'>
                    <a href='/pricing' class='pricing-btn pricing-btn-cta' style='width:auto; padding:0.7rem 1.75rem;'>See Premium plans</a>
                    <a href='/billing' class='pricing-btn pricing-btn-ghost' style='width:auto; padding:0.7rem 1.5rem;'>Upgrade now</a>
                </div>
            </div>
        </div>
    {{else}}
        {{!-- Dimension switcher --}}
        <div class='section-container'>
            <div class='flex items-center justify-between flex-wrap gap-3 mb-4'>
                <div class='inline-flex rounded-lg border border-gray-200 dark:border-midnight-600 bg-gray-50 dark:bg-midnight-800 p-1'>
                    <a href='/portfolio/breakdown?by=set' class='breakdown-tab {{#if (eq dimension "set")}}active{{/if}}'>By Set</a>
                    <a href='/portfolio/breakdown?by=rarity' class='breakdown-tab {{#if (eq dimension "rarity")}}active{{/if}}'>By Rarity</a>
                    <a href='/portfolio/breakdown?by=type' class='breakdown-tab {{#if (eq dimension "type")}}active{{/if}}'>By Type</a>
                </div>
                <div class='text-sm text-gray-600 dark:text-gray-400'>
                    Total: <span class='font-mono font-semibold text-gray-900 dark:text-gray-100'>{{totalValueFormatted}}</span>
                    <span class='mx-2'>&middot;</span>
                    {{totalItems}} item{{#unless (eq totalItems 1)}}s{{/unless}}
                </div>
            </div>

            {{#if slices.length}}
                <div class='breakdown-list'>
                    {{#each slices}}
                        <div class='breakdown-row'>
                            <div class='breakdown-row-header'>
                                <span class='breakdown-label'>{{label}}</span>
                                <span class='breakdown-stats'>
                                    <span class='breakdown-percent'>{{percentFormatted}}</span>
                                    <span class='breakdown-value'>{{valueFormatted}}</span>
                                </span>
                            </div>
                            <div class='breakdown-bar'>
                                <div class='breakdown-bar-fill' style='width: {{percentFormatted}};'></div>
                            </div>
                            <div class='breakdown-meta'>{{cardCount}} unique &middot; {{itemCount}} item{{#unless (eq itemCount 1)}}s{{/unless}}</div>
                        </div>
                    {{/each}}
                </div>
            {{else}}
                {{>emptyState
                    icon='chart-bar'
                    heading='Nothing to break down yet'
                    message='Add cards to your inventory and your collection will appear here, sliced by set, rarity, and type.'
                    hint='Analytics get more interesting as your collection grows.'
                    hintWide=true
                    buttonHref='/sets'
                    buttonText='Browse Sets'
                }}
            {{/if}}
        </div>
    {{/if}}
</div>
